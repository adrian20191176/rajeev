---
import "../styles/global.css";
import { CATEGORIES, PRODUCTS, BUSINESS } from "../data/rcb";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noIndex?: boolean;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = "Royal Crown Bearings supplies premium bearings, V-belts, oil seals and industrial components across Sri Lanka. NTN, NSK, NACHI, FAG, SKF, KOYO and more.",
  ogImage = "/og-default.jpg",
  canonical,
  noIndex = false,
  jsonLd,
} = Astro.props;

const siteUrl     = "https://royalcrownbearings.com";
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const fullTitle   = title === "Royal Crown Bearings" ? title : `${title} | Royal Crown Bearings`;

// Search data (slim subset for fast client search)
const searchCategories = CATEGORIES.map(({ slug, name, short, family }) => ({ slug, name, short, family }));
const searchProducts   = PRODUCTS.map(({ id, name, code, brand, diameter, category, family, iconType, image }) => ({ id, name, code, brand, diameter, category, family, iconType, image }));

// LocalBusiness JSON-LD
const localBusinessLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": BUSINESS.name,
  "description": BUSINESS.mission,
  "url": siteUrl,
  "telephone": BUSINESS.phone,
  "email": BUSINESS.email,
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "LK",
    "addressLocality": "Colombo",
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
    "opens": "00:00",
    "closes": "23:59",
  },
  "sameAs": [`https://wa.me/${BUSINESS.whatsapp}`],
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />

  <!-- Primary SEO -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonicalUrl} />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`} />
  <meta property="og:site_name"   content="Royal Crown Bearings" />
  <meta property="og:locale"      content="en_LK" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`} />

  <!-- Extra meta -->
  <meta name="theme-color" content="#05080F" />
  <meta name="keywords"    content="bearings Sri Lanka, NTN NSK FAG SKF bearings, V-belts, oil seals, industrial components, Colombo bearings supplier" />
  <meta name="author"      content="Royal Crown Bearings" />
  <meta name="geo.region"  content="LK" />
  <meta name="geo.placename" content="Colombo, Sri Lanka" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Manrope:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/logo.svg" />

  <!-- JSON-LD -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd ?? localBusinessLd)} />

  <!-- Embedded search data for client-side search -->
  <script is:inline id="rcb-search-data" type="application/json" set:html={JSON.stringify({ categories: searchCategories, products: searchProducts })} />
</head>
<body class="font-body antialiased">

  <!-- ── Navigation ─────────────────────────────────────────────────── -->
  <slot name="navbar" />

  <!-- ── Page content ───────────────────────────────────────────────── -->
  <slot />

  <!-- ── Footer ─────────────────────────────────────────────────────── -->
  <slot name="footer" />

  <!-- ── Toast container ────────────────────────────────────────────── -->
  <div id="toast-container" aria-live="polite"></div>

  <!-- ── Search palette ─────────────────────────────────────────────── -->
  <div id="search-palette" hidden role="dialog" aria-modal="true" aria-label="Search products and categories"
       onclick="if(event.target===this)closeSearchPalette()">
    <div class="relative max-w-2xl mx-auto chrome-border rounded-xl bg-ink-800/95 shadow-card overflow-hidden fade-up">
      <div class="flex items-center gap-3 px-4 py-3 border-b hairline">
        <!-- Search icon -->
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" class="text-chrome-200/70 shrink-0">
          <circle cx="11" cy="11" r="6"/><line x1="20" y1="20" x2="15.5" y2="15.5"/>
        </svg>
        <input id="search-input" type="search" autocomplete="off" spellcheck="false"
               placeholder="Search bearings, V-belts, brands, part codes…"
               class="flex-1 bg-transparent outline-none text-chrome-50 placeholder-chrome-200/40 text-[15px]" />
        <button onclick="closeSearchPalette()"
                class="text-chrome-200/60 hover:text-chrome-50 font-mono text-[10px] tracking-[0.22em] uppercase border hairline rounded px-2 py-1 transition-colors">
          ESC
        </button>
      </div>
      <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2"></div>
    </div>
  </div>

  <!-- ── Enquiry modal ───────────────────────────────────────────────── -->
  <div id="enquiry-modal" hidden class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="enquiry-modal-title"
       onclick="if(event.target===this)closeEnquiryModal()">
    <div class="relative w-full max-w-2xl chrome-border rounded-xl bg-ink-800/95 shadow-card max-h-[92vh] overflow-y-auto fade-up">
      <form id="enquiry-form" class="p-6 md:p-8" novalidate>
        <div class="flex items-start justify-between gap-6 mb-6">
          <div>
            <div class="flex items-center gap-2 font-mono text-[11px] tracking-[0.28em] uppercase">
              <span class="inline-block w-6 h-px bg-amber-signal"></span>
              <span class="text-amber-signal">Send Enquiry</span>
            </div>
            <h3 id="enquiry-modal-title" class="font-display text-2xl font-semibold tracking-tight text-chrome-50 mt-2">
              Tell us what you need
            </h3>
            <p class="text-sm text-chrome-100/70 mt-1">Our team typically replies within 1 business hour.</p>
          </div>
          <button type="button" onclick="closeEnquiryModal()"
                  class="p-2 rounded-md border hairline-strong text-chrome-100 hover:text-chrome-50 transition-colors shrink-0"
                  aria-label="Close enquiry modal">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
              <line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/>
            </svg>
          </button>
        </div>

        <!-- Selected products injected here by JS -->
        <div id="enquiry-products-list"></div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <!-- Full Name -->
          <label class="block">
            <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-chrome-200/70 mb-1.5">Full Name</div>
            <input type="text" name="name" placeholder="e.g. Nuwan Perera" required
                   class="w-full px-3 py-2.5 rounded-md border border-white/10 bg-ink-900/70 text-chrome-50 text-sm placeholder-chrome-200/30 focus:border-cyan-brand/60 outline-none transition-colors" />
          </label>
          <!-- Phone -->
          <label class="block">
            <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-chrome-200/70 mb-1.5">Phone / WhatsApp</div>
            <input type="tel" name="phone" placeholder="+94 7X XXX XXXX" required
                   class="w-full px-3 py-2.5 rounded-md border border-white/10 bg-ink-900/70 text-chrome-50 text-sm placeholder-chrome-200/30 focus:border-cyan-brand/60 outline-none transition-colors" />
          </label>
          <!-- Email -->
          <div class="sm:col-span-2">
            <label class="block">
              <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-chrome-200/70 mb-1.5">Email</div>
              <input type="email" name="email" placeholder="you@example.com" required
                     class="w-full px-3 py-2.5 rounded-md border border-white/10 bg-ink-900/70 text-chrome-50 text-sm placeholder-chrome-200/30 focus:border-cyan-brand/60 outline-none transition-colors" />
            </label>
          </div>
          <!-- Message -->
          <div class="sm:col-span-2">
            <label class="block">
              <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-chrome-200/70 mb-1.5">Message</div>
              <textarea name="message" rows="4" placeholder="Quantities, delivery location, urgency, application notes…" required
                        class="w-full px-3 py-2.5 rounded-md border border-white/10 bg-ink-900/70 text-chrome-50 text-sm placeholder-chrome-200/30 focus:border-cyan-brand/60 outline-none resize-none transition-colors"></textarea>
            </label>
          </div>
        </div>

        <div class="mt-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
          <p class="text-[12px] text-chrome-200/60 font-mono tracking-[0.06em]">
            By submitting you agree to be contacted about this enquiry only.
          </p>
          <div class="flex items-center gap-2 shrink-0">
            <button type="button" onclick="closeEnquiryModal()"
                    class="inline-flex items-center justify-center gap-2 font-medium tracking-tight rounded-md transition-all duration-200 px-4 py-2.5 text-sm border hairline-strong text-chrome-50 hover:border-cyan-brand/60 hover:text-cyan-brand bg-ink-800/40 backdrop-blur btn-shine">
              Cancel
            </button>
            <button type="submit"
                    class="inline-flex items-center justify-center gap-2 font-medium tracking-tight rounded-md transition-all duration-200 px-5 py-3.5 text-[15px] bg-amber-signal text-ink-900 hover:bg-white hover:shadow-glow-amber btn-shine">
              Send Enquiry
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="13,6 19,12 13,18"/>
              </svg>
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <!-- ── Global app init ────────────────────────────────────────────── -->
  <script>
    import { initGlobal } from '../scripts/rcb';
    initGlobal();
  </script>

</body>
</html>
