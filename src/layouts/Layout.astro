---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { getCategories, getProducts } from '../data/rcb.js';

interface Props {
  title?: string;
  description?: string;
  activeNav?: string;
}

const {
  title = 'Royal Crown Bearings — Powering Performance, Ensuring Reliability',
  description = 'Royal Crown Bearings supplies premium bearings, V-belts, oil seals and industrial components across Sri Lanka.',
  activeNav,
} = Astro.props;

const [PRODUCTS, CATEGORIES] = await Promise.all([getProducts(), getCategories()]);

const searchIndex = PRODUCTS.map(p => ({
  id: p.id, code: p.code, name: p.name, brand: p.brand,
  diameter: p.diameter, category: p.category, family: p.family,
}));
const catIndex = CATEGORIES.map(c => ({
  slug: c.slug, name: c.name, family: c.family, short: c.short,
}));
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Manrope:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <script is:inline>
    /* Flag <html> so CSS can pre-hide animated elements (prevents flash before GSAP runs). */
    document.documentElement.classList.add('rcb-anim');
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.documentElement.classList.add('rcb-no-anim');
    }
  </script>
</head>
<body class="font-body antialiased min-h-screen flex flex-col">

  <Nav activeNav={activeNav} />

  <main class="flex-1">
    <slot />
  </main>

  <Footer />

  <!-- ── Search palette ─────────────────────────────────────────────── -->
  <dialog id="search-dialog" class="fixed inset-0 w-full max-w-2xl mx-auto mt-16 sm:mt-24 p-0 rounded-xl bg-ink-700 border hairline shadow-card fade-up max-h-[70vh] overflow-hidden">
    <div class="flex items-center gap-3 px-4 py-3 border-b hairline">
      <svg class="text-chrome-200 shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><circle cx="11" cy="11" r="6"/><line x1="20" y1="20" x2="15.5" y2="15.5"/></svg>
      <input id="search-input" type="text" placeholder="Search bearings, V-belts, brands, part codes…"
        class="flex-1 bg-transparent outline-none text-chrome-50 placeholder-chrome-200/40 text-base" autocomplete="off" />
      <button id="search-close" class="font-mono text-[10px] tracking-widest uppercase border hairline rounded px-2 py-1 text-chrome-200 hover:text-chrome-50">ESC</button>
    </div>
    <div id="search-results" class="overflow-y-auto max-h-[calc(70vh-3.5rem)] p-2"></div>
  </dialog>

  <!-- ── Enquiry modal ───────────────────────────────────────────────── -->
  <dialog id="enquiry-dialog" class="fixed inset-0 w-full max-w-2xl mx-auto my-auto p-0 rounded-xl bg-ink-700 border hairline shadow-card fade-up max-h-[92vh] overflow-y-auto">
    <form id="modal-enquiry-form" class="p-6 md:p-8">
      <div class="flex items-start justify-between gap-6 mb-6">
        <div>
          <div class="flex items-center gap-2 font-mono text-[11px] tracking-widest uppercase text-gold mb-2">
            <span class="inline-block w-6 h-px bg-gold"></span>Send Enquiry
          </div>
          <h3 id="enquiry-title" class="font-display text-2xl font-semibold tracking-tight text-chrome-50">Tell us what you need</h3>
          <p class="text-sm text-chrome-100/70 mt-1">Our team typically replies within 1 business hour.</p>
        </div>
        <button type="button" id="enquiry-close" class="p-2 rounded-md border hairline-strong text-chrome-100 hover:text-chrome-50">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
        </button>
      </div>
      <div id="enquiry-products-list" class="mb-5 rounded-md border hairline bg-ink-900/40 hidden">
        <div class="px-3 py-2 font-mono text-[10px] tracking-widest uppercase text-chrome-200/60 border-b hairline">Selected Products</div>
        <ul id="enquiry-products-ul" class="divide-y divide-white/[0.04] max-h-40 overflow-y-auto"></ul>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <label class="block">
          <span class="font-mono text-[10px] tracking-widest uppercase text-chrome-200/70 mb-1.5 block">Full Name</span>
          <input name="name" type="text" placeholder="e.g. Nuwan Perera" required
            class="w-full px-3 py-2.5 rounded-md border hairline bg-ink-900/70 text-chrome-50 text-sm placeholder-chrome-200/30 focus:border-gold/60 outline-none" />
        </label>
        <label class="block">
          <span class="font-mono text-[10px] tracking-widest uppercase text-chrome-200/70 mb-1.5 block">Phone / WhatsApp</span>
          <input name="phone" type="tel" placeholder="+94 7X XXX XXXX" required
            class="w-full px-3 py-2.5 rounded-md border hairline bg-ink-900/70 text-chrome-50 text-sm placeholder-chrome-200/30 focus:border-gold/60 outline-none" />
        </label>
        <div class="sm:col-span-2">
          <label class="block">
            <span class="font-mono text-[10px] tracking-widest uppercase text-chrome-200/70 mb-1.5 block">Email</span>
            <input name="email" type="email" placeholder="you@example.com" required
              class="w-full px-3 py-2.5 rounded-md border hairline bg-ink-900/70 text-chrome-50 text-sm placeholder-chrome-200/30 focus:border-gold/60 outline-none" />
          </label>
        </div>
        <div class="sm:col-span-2">
          <label class="block">
            <span class="font-mono text-[10px] tracking-widest uppercase text-chrome-200/70 mb-1.5 block">Message</span>
            <textarea name="message" rows="4" placeholder="Quantities, delivery location, urgency, application notes…" required
              class="w-full px-3 py-2.5 rounded-md border hairline bg-ink-900/70 text-chrome-50 text-sm placeholder-chrome-200/30 focus:border-gold/60 outline-none resize-none"></textarea>
          </label>
        </div>
      </div>
      <div class="mt-6 flex items-center justify-between gap-3">
        <p class="text-[12px] text-chrome-200/60 font-mono tracking-wide">By submitting you agree to be contacted about this enquiry only.</p>
        <div class="flex items-center gap-2">
          <button type="button" id="enquiry-cancel" class="inline-flex items-center px-4 py-2.5 text-sm font-medium tracking-tight rounded-md border hairline-strong text-chrome-50 hover:border-gold/60 bg-ink-600/40">Cancel</button>
          <button type="submit" class="btn-shine inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium tracking-tight rounded-md bg-amber-signal text-ink-900 hover:bg-gold">
            Send Enquiry
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13,6 19,12 13,18"/></svg>
          </button>
        </div>
      </div>
    </form>
  </dialog>

  <!-- ── Toast container ────────────────────────────────────────────── -->
  <div id="toast-stack" class="fixed bottom-6 right-4 sm:right-6 z-[80] flex flex-col gap-2 w-[340px] max-w-[calc(100vw-2rem)] pointer-events-none"></div>

  <!-- ── Serialised search data ──────────────────────────────────────── -->
  <script id="rcb-search-data" type="application/json" set:html={JSON.stringify({ products: searchIndex, categories: catIndex })}></script>

  <script>
    import { supabase } from '../lib/supabase';

    // ── Global type extensions ─────────────────────────────────────────
    declare global {
      interface Window {
        showToast: (opts: { title: string; message?: string; tone?: string }) => void;
        rcbList: {
          get: () => any[];
          add: (p: any) => void;
          remove: (id: number) => void;
          clear: () => void;
        };
        openEnquiry: (products?: any[]) => void;
        submitEnquiry: (data: {
          name: string;
          phone?: string;
          email?: string;
          company?: string;
          message?: string;
          source: string;
          products?: Array<{ id: number; quantity?: number; note?: string }>;
        }) => Promise<{ id: number }>;
      }
    }

    // ── Persist an enquiry to Supabase (header + items) ──────────────
    // Shared by the modal in this layout AND the inline form on /enquiry-list.
    async function submitEnquiry(data: {
      name: string; phone?: string; email?: string; company?: string;
      message?: string; source: string;
      products?: Array<{ id: number; quantity?: number; note?: string }>;
    }): Promise<{ id: number }> {
      const { data: row, error } = await supabase
        .from('enquiries')
        .insert({
          name:    data.name,
          phone:   data.phone   || null,
          email:   data.email   || null,
          company: data.company || null,
          message: data.message || null,
          source:  data.source,
        })
        .select('id')
        .single();
      if (error) throw new Error(error.message);

      if (data.products && data.products.length > 0) {
        const items = data.products.map(p => ({
          enquiry_id: row.id,
          product_id: p.id,
          quantity:   p.quantity ?? 1,
          note:       p.note ?? null,
        }));
        const { error: itemsErr } = await supabase.from('enquiry_items').insert(items);
        if (itemsErr) throw new Error(`Saved enquiry but items failed: ${itemsErr.message}`);
      }
      return { id: row.id };
    }
    window.submitEnquiry = submitEnquiry;

    // ── Utilities ─────────────────────────────────────────────────────
    const STORAGE_KEY = 'rcb.enquiryList.v1';

    function getList(): any[] {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch { return []; }
    }
    function saveList(list: any[]) {
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(list)); } catch {}
      window.dispatchEvent(new CustomEvent('rcb:list-updated'));
    }

    // ── Toast ─────────────────────────────────────────────────────────
    function showToast({ title, message = '', tone = 'info' }: { title: string; message?: string; tone?: string }) {
      const stack = document.getElementById('toast-stack');
      if (!stack) return;
      const el = document.createElement('div');
      const colors: Record<string, string> = {
        success: 'bg-emerald-500/10 border-emerald-500/30',
        error:   'bg-red-500/10 border-red-400/30',
        info:    'bg-ink-500/80 border-white/10',
      };
      const iconCol = tone === 'success' ? 'bg-emerald-500/20 text-emerald-300' : tone === 'error' ? 'bg-red-500/20 text-red-300' : 'bg-gold/20 text-gold';
      const icon = tone === 'success'
        ? '<polyline points="5,12 10,17 19,7"/>'
        : tone === 'error'
        ? '<line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/>'
        : '<path d="M12 2l1.6 5.4L19 9l-5.4 1.6L12 16l-1.6-5.4L5 9l5.4-1.6z"/>';
      el.className = `toast-in chrome-border rounded-lg px-4 py-3 flex items-start gap-3 backdrop-blur-md border pointer-events-auto ${colors[tone] ?? colors['info']}`;
      el.innerHTML = `
        <div class="mt-0.5 grid place-items-center w-6 h-6 rounded-full shrink-0 ${iconCol}">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">${icon}</svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="text-sm font-medium text-chrome-50">${title}</div>
          ${message ? `<div class="text-[12.5px] text-chrome-100/80 mt-0.5">${message}</div>` : ''}
        </div>
        <button class="text-chrome-200/60 hover:text-chrome-50 shrink-0" onclick="this.closest('.toast-in').remove()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
        </button>`;
      stack.appendChild(el);
      setTimeout(() => el.remove(), 4500);
    }
    window.showToast = showToast;

    // ── Enquiry list public API ────────────────────────────────────────
    window.rcbList = {
      get: getList,
      add(product: any) {
        const list = getList();
        if (list.some((p: any) => p.id === product.id)) {
          showToast({ title: 'Already in your Enquiry List', message: product.name });
          return;
        }
        list.push(product);
        saveList(list);
        showToast({ tone: 'success', title: 'Added to Enquiry List', message: product.name });
      },
      remove(id: number) {
        saveList(getList().filter((p: any) => p.id !== id));
        showToast({ title: 'Removed from Enquiry List' });
      },
      clear() {
        saveList([]);
        showToast({ title: 'Enquiry List cleared' });
      },
    };

    // ── Enquiry count badge in nav ─────────────────────────────────────
    function refreshCount() {
      const el = document.getElementById('enquiry-count');
      if (!el) return;
      const n = getList().length;
      el.textContent = String(n);
      if (n > 0) {
        el.classList.add('bg-amber-signal', 'text-ink-900');
        el.classList.remove('bg-ink-500', 'text-chrome-100');
      } else {
        el.classList.remove('bg-amber-signal', 'text-ink-900');
        el.classList.add('bg-ink-500', 'text-chrome-100');
      }
    }
    refreshCount();
    window.addEventListener('rcb:list-updated', refreshCount);

    // ── Search palette ─────────────────────────────────────────────────
    const searchDialog  = document.getElementById('search-dialog') as HTMLDialogElement | null;
    const searchInput   = document.getElementById('search-input')  as HTMLInputElement | null;
    const searchClose   = document.getElementById('search-close');
    const searchResults = document.getElementById('search-results');
    let searchData: { products: any[]; categories: any[] } = { products: [], categories: [] };
    try {
      const raw = document.getElementById('rcb-search-data')?.textContent ?? '{}';
      searchData = JSON.parse(raw);
    } catch {}

    function openSearch() {
      searchDialog?.showModal();
      if (searchInput) searchInput.value = '';
      renderSearchResults('');
      setTimeout(() => searchInput?.focus(), 30);
    }
    function closeSearch() { searchDialog?.close(); }

    searchInput?.addEventListener('input', (e) => renderSearchResults((e.target as HTMLInputElement).value.trim()));
    searchClose?.addEventListener('click', closeSearch);
    searchDialog?.addEventListener('click', (e) => { if (e.target === searchDialog) closeSearch(); });

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') { e.preventDefault(); openSearch(); }
      if (e.key === 'Escape' && searchDialog?.open) closeSearch();
    });

    document.querySelectorAll('.open-search').forEach(btn => btn.addEventListener('click', openSearch));

    function renderSearchResults(q: string) {
      if (!searchResults) return;
      const lq = q.toLowerCase();
      const cats = q
        ? searchData.categories.filter((c: any) => c.name.toLowerCase().includes(lq) || c.family.toLowerCase().includes(lq)).slice(0, 4)
        : searchData.categories.slice(0, 4);
      const prods = q
        ? searchData.products.filter((p: any) => p.name.toLowerCase().includes(lq) || p.code.toLowerCase().includes(lq) || p.brand.toLowerCase().includes(lq)).slice(0, 8)
        : searchData.products.slice(0, 6);

      let html = '';
      if (cats.length) {
        html += `<div class="px-3 pt-3 pb-2 font-mono text-[10px] tracking-widest uppercase text-chrome-200/60">Categories</div><ul class="mb-2">`;
        cats.forEach((c: any) => {
          html += `<li><a href="/categories/${c.slug}" onclick="document.getElementById('search-dialog').close()"
            class="flex items-center justify-between gap-3 px-3 py-2.5 rounded-md hover:bg-ink-600/70">
            <div>
              <div class="text-chrome-50 text-sm">${c.name}</div>
              <div class="text-[12px] text-chrome-200/60">${c.short}</div>
            </div>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="text-chrome-200/50 shrink-0"><polyline points="9,6 15,12 9,18"/></svg>
          </a></li>`;
        });
        html += '</ul>';
      }
      if (prods.length) {
        html += `<div class="px-3 pt-2 pb-2 font-mono text-[10px] tracking-widest uppercase text-chrome-200/60">Products</div><ul>`;
        prods.forEach((p: any) => {
          html += `<li><a href="/products/${p.id}" onclick="document.getElementById('search-dialog').close()"
            class="flex items-center justify-between gap-3 px-3 py-2.5 rounded-md hover:bg-ink-600/70">
            <div>
              <div class="text-chrome-50 text-sm font-mono">${p.code}</div>
              <div class="text-[12px] text-chrome-200/60">${p.diameter}</div>
            </div>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="text-chrome-200/50 shrink-0"><polyline points="9,6 15,12 9,18"/></svg>
          </a></li>`;
        });
        html += '</ul>';
      }
      if (!cats.length && !prods.length && q) {
        html = `<div class="px-4 py-12 text-center text-chrome-200/60 text-sm">No results for "${q}". Try a part code, brand, or category.</div>`;
      }
      searchResults.innerHTML = html;
    }

    // ── Enquiry modal ──────────────────────────────────────────────────
    const enquiryDialog = document.getElementById('enquiry-dialog')       as HTMLDialogElement | null;
    const enquiryForm   = document.getElementById('modal-enquiry-form')   as HTMLFormElement | null;
    const enquiryClose  = document.getElementById('enquiry-close');
    const enquiryCancel = document.getElementById('enquiry-cancel');

    let currentEnquiryProducts: any[] = [];

    function openEnquiry(products: any[] = []) {
      currentEnquiryProducts = products;
      const titleEl   = document.getElementById('enquiry-title');
      const listWrap  = document.getElementById('enquiry-products-list');
      const listUl    = document.getElementById('enquiry-products-ul');

      if (titleEl) {
        titleEl.textContent = products.length > 1
          ? `Enquire about ${products.length} products`
          : 'Tell us what you need';
      }
      if (products.length > 0) {
        listWrap?.classList.remove('hidden');
        if (listUl) {
          listUl.innerHTML = products.map((p: any) =>
            `<li class="px-3 py-2 flex items-center justify-between text-sm">
              <span class="text-chrome-50 font-medium">${p.name}</span>
              <span class="font-mono text-[11px] text-gold/80">${p.diameter ?? ''}</span>
            </li>`
          ).join('');
        }
      } else {
        listWrap?.classList.add('hidden');
      }
      enquiryDialog?.showModal();
    }
    window.openEnquiry = openEnquiry;

    enquiryClose?.addEventListener('click', () => enquiryDialog?.close());
    enquiryCancel?.addEventListener('click', () => enquiryDialog?.close());
    enquiryDialog?.addEventListener('click', (e) => { if (e.target === enquiryDialog) enquiryDialog?.close(); });

    // Animate added-to-list count badge in the nav
    let lastCount = getList().length;
    window.addEventListener('rcb:list-updated', () => {
      const el = document.getElementById('enquiry-count');
      const n = getList().length;
      if (el && (window as any).rcbAnim?.gsap && n !== lastCount) {
        (window as any).rcbAnim.gsap.fromTo(el,
          { scale: 0.6, rotate: -10 },
          { scale: 1, rotate: 0, duration: 0.55, ease: 'elastic.out(1, 0.5)' }
        );
      }
      lastCount = n;
    });

    enquiryForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.currentTarget as HTMLFormElement;
      const btn = form.querySelector<HTMLButtonElement>('[type=submit]');
      if (!btn) return;
      const fd = new FormData(form);
      const originalLabel = btn.textContent;
      btn.textContent = 'Sending…';
      btn.disabled = true;

      try {
        await submitEnquiry({
          name:    String(fd.get('name')    ?? '').trim(),
          phone:   String(fd.get('phone')   ?? '').trim(),
          email:   String(fd.get('email')   ?? '').trim(),
          message: String(fd.get('message') ?? '').trim(),
          source:  'enquiry-modal',
          products: currentEnquiryProducts.map((p: any) => ({ id: p.id })),
        });
        enquiryDialog?.close();
        showToast({ tone: 'success', title: 'Enquiry sent successfully', message: 'Our team will reply within the hour.' });
        form.reset();
        if (currentEnquiryProducts.length > 0) window.rcbList?.clear();
        currentEnquiryProducts = [];
      } catch (err: any) {
        showToast({ tone: 'error', title: "Couldn't send enquiry", message: err?.message || 'Please try again, or WhatsApp +94 766 550 249.' });
      } finally {
        btn.textContent = originalLabel;
        btn.disabled = false;
      }
    });
  </script>

  <!-- ── GSAP animations (bundled) ─────────────────────────────────── -->
  <script>
    import '../scripts/animations';
  </script>
</body>
</html>
