---
import Layout from "../layouts/Layout.astro";
import { BUSINESS } from "../data/rcb.js";

const waBase = `https://wa.me/${BUSINESS.whatsapp}`;
---

<Layout
  title="Enquiry List | Royal Crown Bearings"
  description="Review your product enquiry list and send your request via WhatsApp or email."
  activeNav=""
>
  <section class="relative border-b hairline overflow-hidden">
    <div class="absolute inset-0 tech-grid pointer-events-none"></div>
    <div
      class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"
    >
    </div>
    <div
      class="relative max-w-7xl mx-auto px-4 md:px-6 pt-10 pb-12 md:pt-16 md:pb-14"
    >
      <div
        class="font-mono text-[10px] tracking-widest uppercase text-gold/70 mb-3 flex items-center gap-2"
      >
        <a href="/" class="hover:text-gold transition-colors">Home</a>
        <span class="text-chrome-200/30">/</span>
        <span>Enquiry List</span>
      </div>
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
          <h1
            data-hero-step
            data-split-words
            class="font-display text-3xl md:text-4xl font-bold text-chrome-50 tracking-tight"
          >
            Enquiry List
          </h1>
          <p data-hero-step class="mt-2 text-chrome-200/60 text-sm" id="list-summary">
            Loading…
          </p>
        </div>
        <button
          id="clear-all-btn"
          data-hero-step
          class="hidden font-mono text-[11px] tracking-wider uppercase px-4 py-2 rounded border border-red-500/30 text-red-400/70 hover:border-red-500/60 hover:text-red-400 transition-colors"
        >
          Clear All
        </button>
      </div>
    </div>
  </section>

  <section data-reveal class="max-w-7xl mx-auto px-4 md:px-6 py-10 md:py-14">
    <!-- Empty state -->
    <div
      id="empty-state"
      class="hidden flex flex-col items-center justify-center py-24 text-center"
    >
      <svg
        class="text-chrome-200/20 mb-4"
        width="56"
        height="56"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M9 4h7l4 4v12a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1z"
        ></path><path d="M15 4v5h5"></path><path d="M11 13h6"></path><path
          d="M11 17h4"></path><path d="M5 8H3"></path><path d="M5 13H3"
        ></path><path d="M5 18H3"></path></svg
      >
      <h2 class="font-display text-xl font-semibold text-chrome-50 mb-2">
        Your enquiry list is empty
      </h2>
      <p class="text-chrome-200/50 text-sm mb-6 max-w-xs">
        Browse categories and add products to build your enquiry.
      </p>
      <a
        href="/categories"
        class="btn-shine inline-flex items-center gap-2 px-5 py-3 rounded-md bg-gold text-ink-900 font-medium text-sm hover:shadow-glow-cyan transition-all"
      >
        Browse Categories
        <svg
          width="13"
          height="13"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
            points="12,5 19,12 12,19"></polyline></svg
        >
      </a>
    </div>

    <!-- List content -->
    <div id="list-content" class="hidden">
      <div
        id="products-table"
        class="rounded-xl border hairline overflow-hidden mb-8"
        style="box-shadow: var(--shadow-card)"
      >
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b hairline bg-ink-700/40">
              <th
                class="text-left px-4 py-3 font-mono text-[10px] tracking-widest uppercase text-chrome-200/50 w-8"
                >#</th
              >
              <th
                class="text-left px-4 py-3 font-mono text-[10px] tracking-widest uppercase text-chrome-200/50"
                >Part Code</th
              >
              <th
                class="text-left px-4 py-3 font-mono text-[10px] tracking-widest uppercase text-chrome-200/50 hidden sm:table-cell"
                >Brand</th
              >
              <th
                class="text-left px-4 py-3 font-mono text-[10px] tracking-widest uppercase text-chrome-200/50 hidden md:table-cell"
                >Dimensions</th
              >
              <th class="px-4 py-3 w-10"></th>
            </tr>
          </thead>
          <tbody id="product-rows"></tbody>
        </table>
      </div>

      <!-- Send actions -->
      <div
        class="rounded-xl border hairline bg-ink-800/50 p-6 md:p-8"
        style="box-shadow: var(--shadow-card)"
      >
        <h2 class="font-display text-lg font-semibold text-chrome-50 mb-1">
          Send Enquiry
        </h2>
        <p class="text-chrome-200/50 text-sm mb-6">
          Choose how you'd like to send your enquiry to Royal Crown Bearings.
        </p>

        <div class="flex flex-wrap gap-3 mb-8">
          <a
            id="whatsapp-btn"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-shine inline-flex items-center gap-2 px-5 py-3 rounded-md bg-emerald-600/90 hover:bg-emerald-500 text-white font-medium text-sm transition-all"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
              ></path><path
                d="M12 0C5.373 0 0 5.373 0 12c0 2.127.557 4.126 1.533 5.862L.057 23.5l5.784-1.517A11.944 11.944 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.816 9.816 0 0 1-5.001-1.372l-.358-.213-3.726.977.995-3.633-.233-.373A9.818 9.818 0 0 1 2.182 12C2.182 6.573 6.573 2.182 12 2.182S21.818 6.573 21.818 12 17.427 21.818 12 21.818z"
              ></path></svg
            >
            Send via WhatsApp
          </a>
          <button
            id="open-form-btn"
            class="btn-shine inline-flex items-center gap-2 px-5 py-3 rounded-md border hairline-strong text-chrome-50 hover:border-gold/60 hover:text-gold font-medium text-sm bg-ink-600/40 transition-all"
          >
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              ><rect x="3" y="5" width="18" height="14" rx="2"></rect><polyline
                points="3,7 12,13 21,7"></polyline></svg
            >
            Send via Email Form
          </button>
        </div>

        <!-- Inline enquiry form -->
        <div id="inline-form" class="hidden">
          <div class="border-t hairline pt-6">
            <h3
              class="font-display text-base font-semibold text-chrome-50 mb-4"
            >
              Contact Details
            </h3>
            <form
              id="enquiry-form"
              class="grid grid-cols-1 sm:grid-cols-2 gap-4"
            >
              <div class="flex flex-col gap-1.5">
                <label
                  class="font-mono text-[10px] tracking-widest uppercase text-chrome-200/60"
                  >Full Name *</label
                >
                <input
                  name="name"
                  required
                  type="text"
                  placeholder="Your name"
                  class="px-3 py-2.5 rounded-md border hairline bg-ink-700/50 text-chrome-50 text-sm placeholder:text-chrome-200/25 focus:outline-none focus:border-gold/40"
                />
              </div>
              <div class="flex flex-col gap-1.5">
                <label
                  class="font-mono text-[10px] tracking-widest uppercase text-chrome-200/60"
                  >Phone Number *</label
                >
                <input
                  name="phone"
                  required
                  type="tel"
                  placeholder="+94 7XX XXX XXX"
                  class="px-3 py-2.5 rounded-md border hairline bg-ink-700/50 text-chrome-50 text-sm placeholder:text-chrome-200/25 focus:outline-none focus:border-gold/40"
                />
              </div>
              <div class="flex flex-col gap-1.5">
                <label
                  class="font-mono text-[10px] tracking-widest uppercase text-chrome-200/60"
                  >Email</label
                >
                <input
                  name="email"
                  type="email"
                  placeholder="you@example.com"
                  class="px-3 py-2.5 rounded-md border hairline bg-ink-700/50 text-chrome-50 text-sm placeholder:text-chrome-200/25 focus:outline-none focus:border-gold/40"
                />
              </div>
              <div class="flex flex-col gap-1.5">
                <label
                  class="font-mono text-[10px] tracking-widest uppercase text-chrome-200/60"
                  >Message</label
                >
                <input
                  name="message"
                  type="text"
                  placeholder="Quantity, urgency, etc."
                  class="px-3 py-2.5 rounded-md border hairline bg-ink-700/50 text-chrome-50 text-sm placeholder:text-chrome-200/25 focus:outline-none focus:border-gold/40"
                />
              </div>
              <div class="sm:col-span-2">
                <button
                  type="submit"
                  class="btn-shine inline-flex items-center gap-2 px-6 py-3 rounded-md bg-gold text-ink-900 font-medium text-sm hover:shadow-glow-cyan transition-all"
                >
                  <svg
                    width="15"
                    height="15"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><line x1="22" y1="2" x2="11" y2="13"></line><polygon
                      points="22,2 15,22 11,13 2,9 22,2"></polygon></svg
                  >
                  Send Enquiry
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script is:inline define:vars={{ waBase }}>
  const KEY = "rcb.enquiryList.v1";

  function load() {
    try {
      return JSON.parse(localStorage.getItem(KEY) || "[]");
    } catch {
      return [];
    }
  }

  function render() {
    const items = load();
    const empty = document.getElementById("empty-state");
    const content = document.getElementById("list-content");
    const summary = document.getElementById("list-summary");
    const clearBtn = document.getElementById("clear-all-btn");
    const rows = document.getElementById("product-rows");
    const waBtn = document.getElementById("whatsapp-btn");

    if (items.length === 0) {
      empty?.classList.remove("hidden");
      content?.classList.add("hidden");
      clearBtn?.classList.add("hidden");
      if (summary) summary.textContent = "0 products added";
      return;
    }

    empty?.classList.add("hidden");
    content?.classList.remove("hidden");
    clearBtn?.classList.remove("hidden");
    if (summary)
      summary.textContent = `${items.length} product${items.length > 1 ? "s" : ""} added`;

    if (rows) {
      rows.innerHTML = items
        .map(
          (p, i) => `
        <tr class="border-b hairline last:border-b-0 hover:bg-ink-700/20 transition-colors">
          <td class="px-4 py-3 font-mono text-[11px] text-chrome-200/30">${i + 1}</td>
          <td class="px-4 py-3">
            <a href="/products/${p.id}" class="font-display text-sm font-semibold text-chrome-50 hover:text-gold transition-colors">${p.code}</a>
            <div class="font-mono text-[9px] tracking-widest uppercase text-chrome-200/40 mt-0.5">${p.name}</div>
          </td>
          <td class="px-4 py-3 text-sm text-chrome-200/70 hidden sm:table-cell">${p.brand}</td>
          <td class="px-4 py-3 font-mono text-xs text-chrome-200/40 hidden md:table-cell">${p.diameter || "—"}</td>
          <td class="px-4 py-3 text-right">
            <button data-remove="${p.id}" class="remove-btn p-1.5 rounded border hairline text-chrome-200/30 hover:border-red-500/40 hover:text-red-400 transition-colors">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </td>
        </tr>
      `,
        )
        .join("");

      rows.querySelectorAll(".remove-btn").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          const id = Number(btn.dataset.remove);
          const row = btn.closest("tr");
          const w = window;
          if (row && w.rcbAnim?.gsap) {
            w.rcbAnim.gsap.to(row, {
              opacity: 0,
              x: 40,
              duration: 0.35,
              ease: "power3.in",
              onComplete: () => { w.rcbList?.remove(id); render(); },
            });
          } else {
            w.rcbList?.remove(id);
            render();
          }
        });
      });

      // Animate rows in
      if (window.rcbAnim?.gsap) {
        const newRows = rows.querySelectorAll("tr");
        window.rcbAnim.gsap.fromTo(newRows,
          { opacity: 0, y: 12 },
          { opacity: 1, y: 0, duration: 0.45, ease: "power3.out", stagger: 0.05 }
        );
      }
    }

    // WhatsApp message
    const lines = [
      "Hi Royal Crown Bearings, I'd like to enquire about the following products:",
      "",
      ...items.map(
        (p, i) =>
          `${i + 1}. ${p.name}${p.diameter ? " (" + p.diameter + ")" : ""}`,
      ),
      "",
      "Please provide availability and pricing. Thank you.",
    ];
    if (waBtn)
      waBtn.href = waBase + "?text=" + encodeURIComponent(lines.join("\n"));
  }

  document.getElementById("clear-all-btn")?.addEventListener("click", () => {
    if (confirm("Clear all products from your enquiry list?")) {
      window.rcbList?.clear();
      render();
    }
  });

  document.getElementById("open-form-btn")?.addEventListener("click", () => {
    const form = document.getElementById("inline-form");
    form?.classList.toggle("hidden");
  });

  document.getElementById("enquiry-form")?.addEventListener("submit", (e) => {
    e.preventDefault();
    const items = load();
    const fd = new FormData(e.target);
    const name = fd.get("name");
    const lines = [
      `New Enquiry from ${name}`,
      `Phone: ${fd.get("phone")}`,
      fd.get("email") ? `Email: ${fd.get("email")}` : "",
      fd.get("message") ? `Message: ${fd.get("message")}` : "",
      "",
      "Products:",
      ...items.map(
        (p, i) =>
          `${i + 1}. ${p.name}${p.diameter ? " (" + p.diameter + ")" : ""}`,
      ),
    ].filter((l) => l !== undefined);
    const waUrl = waBase + "?text=" + encodeURIComponent(lines.join("\n"));
    window.open(waUrl, "_blank", "noopener");
    window.showToast?.({
      title: "Enquiry sent via WhatsApp!",
      tone: "success",
    });
  });

  window.addEventListener("rcb:list-updated", render);
  render();
</script>
