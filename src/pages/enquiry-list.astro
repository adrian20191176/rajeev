---
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import { BUSINESS } from "../data/rcb";
---

<Layout
  title="Enquiry List — Royal Crown Bearings"
  description="Review your selected products and send a consolidated enquiry to Royal Crown Bearings Sri Lanka. Get a fast quote by phone, WhatsApp or email."
  noIndex={true}
>
  <NavBar slot="navbar" currentPath="/enquiry-list" />

  <div class="max-w-5xl mx-auto px-5 sm:px-6 pt-28 pb-20 min-h-screen">
    <!-- Header -->
    <nav class="flex items-center gap-2 font-mono text-[11px] tracking-[0.2em] uppercase text-chrome-200/50 mb-10 gsap-reveal" aria-label="Breadcrumb">
      <a href="/" class="hover:text-cyan-brand transition-colors">Home</a>
      <span class="text-chrome-200/30">/</span>
      <span class="text-chrome-200/80">Enquiry List</span>
    </nav>

    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-10">
      <div>
        <div class="flex items-center gap-3 font-mono text-[11px] tracking-[0.28em] uppercase mb-3 gsap-reveal">
          <span class="inline-block w-6 h-px bg-amber-signal"></span>
          <span class="text-amber-signal">Your Shortlist</span>
        </div>
        <h1 class="font-display text-3xl sm:text-4xl font-bold tracking-tight text-chrome-50 gsap-reveal">Enquiry List</h1>
        <p class="mt-2 text-chrome-100/60 text-sm gsap-reveal" id="list-subtitle">Loading your items…</p>
      </div>

      <div class="flex items-center gap-2 gsap-reveal" id="list-actions" style="display:none!important">
        <button onclick="openEnquiryModal(window.__enquiryList ?? [])"
                class="inline-flex items-center gap-2 font-medium tracking-tight rounded-md transition-all px-4 py-2.5 text-sm bg-amber-signal text-ink-900 hover:bg-white hover:shadow-glow-amber btn-shine">
          Send Enquiry
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="13,6 19,12 13,18"/>
          </svg>
        </button>
        <a href={`https://wa.me/${BUSINESS.whatsapp.replace('+','')}?text=`} id="wa-btn" target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 font-medium tracking-tight rounded-md transition-all px-4 py-2.5 text-sm border hairline-strong bg-ink-800/40 text-chrome-50 hover:border-amber-signal/50 hover:text-amber-signal btn-shine">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
            <path d="M20.5 3.5A11 11 0 0 0 3.7 17.3L2 22l4.8-1.6A11 11 0 1 0 20.5 3.5z"/>
          </svg>
          WhatsApp List
        </a>
        <button onclick="clearEnquiry()" aria-label="Clear list"
                class="p-2.5 rounded-md border hairline-strong bg-ink-800/40 text-chrome-200/60 hover:text-red-400 hover:border-red-400/40 transition-all">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Product list (rendered by JS) -->
    <div id="enquiry-items" class="flex flex-col gap-3"></div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden py-24 text-center">
      <div class="w-20 h-20 mx-auto mb-6 rounded-full border hairline-strong bg-ink-800/60 grid place-items-center opacity-50">
        <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="rgba(194,204,219,0.5)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 4h7l4 4v12a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1z"/>
          <path d="M15 4v5h5"/>
          <path d="M11 13h6"/><path d="M11 17h4"/>
        </svg>
      </div>
      <h2 class="font-display text-2xl font-semibold text-chrome-50 mb-2">Your list is empty</h2>
      <p class="text-chrome-100/60 mb-8">Add products while browsing to build your enquiry list.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/categories"
           class="inline-flex items-center gap-2 font-medium tracking-tight rounded-md transition-all px-5 py-3 text-sm bg-amber-signal text-ink-900 hover:bg-white hover:shadow-glow-amber btn-shine">
          Browse Categories
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="13,6 19,12 13,18"/>
          </svg>
        </a>
        <button onclick="openSearchPalette()"
                class="inline-flex items-center gap-2 font-medium tracking-tight rounded-md transition-all px-5 py-3 text-sm border hairline-strong text-chrome-50 hover:border-cyan-brand/50 hover:text-cyan-brand bg-ink-800/40 btn-shine">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
            <circle cx="11" cy="11" r="6"/><line x1="20" y1="20" x2="15.5" y2="15.5"/>
          </svg>
          Search Parts
        </button>
      </div>
    </div>

    <!-- Summary footer (shown when items exist) -->
    <div id="list-summary" class="mt-8 chrome-border rounded-xl bg-ink-800/60 p-5 hidden">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-chrome-200/50 mb-1">Total Selected</div>
          <div class="font-display text-xl font-semibold text-chrome-50" id="summary-count">0 items</div>
        </div>
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2 w-full sm:w-auto">
          <button onclick="openEnquiryModal(window.__enquiryList ?? [])"
                  class="inline-flex items-center justify-center gap-2 font-medium tracking-tight rounded-md transition-all px-5 py-3 text-sm bg-amber-signal text-ink-900 hover:bg-white hover:shadow-glow-amber btn-shine">
            Send Full Enquiry
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="13,6 19,12 13,18"/>
            </svg>
          </button>
          <a href={`https://wa.me/${BUSINESS.whatsapp.replace('+','')}?text=`} id="wa-btn-2" target="_blank" rel="noopener"
             class="inline-flex items-center justify-center gap-2 font-medium tracking-tight rounded-md transition-all px-5 py-3 text-sm border hairline-strong text-chrome-50 hover:border-amber-signal/50 hover:text-amber-signal bg-ink-800/40 btn-shine">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
              <path d="M20.5 3.5A11 11 0 0 0 3.7 17.3L2 22l4.8-1.6A11 11 0 1 0 20.5 3.5z"/>
            </svg>
            WhatsApp Enquiry
          </a>
        </div>
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</Layout>

<script>
  import gsap from 'gsap';

  gsap.fromTo('.gsap-reveal',
    { opacity: 0, y: 16 },
    { opacity: 1, y: 0, duration: 0.5, stagger: 0.09, ease: 'power2.out', delay: 0.1 }
  );

  const STORAGE_KEY = 'rcb.enquiryList.v1';

  type StoredItem = { id: number; name: string; code: string; brand: string; category: string; diameter?: string; family?: string; iconType?: string; };

  function getList(): StoredItem[] {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch { return []; }
  }

  function saveList(list: StoredItem[]) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(list));
    (window as any).__enquiryList = list;
    updateCountBadges(list.length);
  }

  function updateCountBadges(n: number) {
    document.querySelectorAll('[data-enquiry-count]').forEach(el => {
      el.textContent = String(n);
    });
  }

  function buildWaText(list: StoredItem[]): string {
    const lines = list.map((p, i) => `${i + 1}. ${p.name} (${p.code}) — ${p.brand}${p.diameter ? ' · ' + p.diameter : ''}`).join('\n');
    return encodeURIComponent(`Hi Royal Crown Bearings,\n\nI'd like to enquire about the following:\n\n${lines}\n\nPlease let me know availability and pricing.`);
  }

  function removeItem(id: number) {
    const list = getList().filter(p => p.id !== id);
    saveList(list);
    render(list);
  }

  function render(list: StoredItem[]) {
    (window as any).__enquiryList = list;

    const container   = document.getElementById('enquiry-items')!;
    const emptyState  = document.getElementById('empty-state')!;
    const listActions = document.getElementById('list-actions')!;
    const listSummary = document.getElementById('list-summary')!;
    const subtitle    = document.getElementById('list-subtitle')!;
    const summaryCount = document.getElementById('summary-count')!;
    const waBtn       = document.getElementById('wa-btn') as HTMLAnchorElement | null;
    const waBtn2      = document.getElementById('wa-btn-2') as HTMLAnchorElement | null;

    const waText = buildWaText(list);
    const waBase = `https://wa.me/94766550249?text=`;
    if (waBtn)  waBtn.href  = waBase + waText;
    if (waBtn2) waBtn2.href = waBase + waText;

    if (list.length === 0) {
      container.innerHTML = '';
      emptyState.classList.remove('hidden');
      listActions.style.removeProperty('display'); listActions.style.display = 'none';
      listSummary.classList.add('hidden');
      subtitle.textContent = '0 items selected';
      return;
    }

    emptyState.classList.add('hidden');
    listActions.style.removeProperty('display');
    listSummary.classList.remove('hidden');
    subtitle.textContent = `${list.length} item${list.length !== 1 ? 's' : ''} selected`;
    summaryCount.textContent = `${list.length} item${list.length !== 1 ? 's' : ''}`;

    container.innerHTML = list.map((p, i) => `
      <div class="item-row chrome-border rounded-xl bg-ink-800/60 px-5 py-4 flex flex-col sm:flex-row sm:items-center gap-4" data-item-id="${p.id}">
        <div class="flex items-center gap-3 flex-1 min-w-0">
          <div class="w-8 h-8 shrink-0 rounded-md border border-white/8 bg-ink-700/60 grid place-items-center font-mono text-[11px] text-chrome-200/50">
            ${i + 1}
          </div>
          <div class="flex-1 min-w-0">
            <div class="font-display text-sm font-semibold text-chrome-50 leading-snug truncate">${p.name}</div>
            <div class="flex items-center gap-2 mt-0.5 flex-wrap">
              <span class="font-mono text-[10px] tracking-[0.16em] text-cyan-brand/80">${p.code}</span>
              <span class="text-chrome-200/30">·</span>
              <span class="font-mono text-[10px] tracking-[0.14em] uppercase text-chrome-200/50">${p.brand}</span>
            </div>
          </div>
        </div>

        <div class="flex items-center gap-2 shrink-0">
          <a href="/products/${p.id}"
             class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md border border-white/8 bg-ink-700/40 hover:border-cyan-brand/40 hover:text-cyan-brand text-chrome-200/70 font-mono text-[10px] tracking-[0.14em] uppercase transition-all">
            View
            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="13,6 19,12 13,18"/>
            </svg>
          </a>
          <button onclick="window.__removeEnquiryItem(${p.id})"
                  class="p-2 rounded-md border border-white/8 bg-ink-700/40 hover:border-red-400/40 hover:text-red-400 text-chrome-200/50 transition-all"
                  aria-label="Remove ${p.name}">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/>
            </svg>
          </button>
        </div>
      </div>
    `).join('');

    // Animate new items
    gsap.fromTo('.item-row',
      { opacity: 0, x: -16 },
      { opacity: 1, x: 0, duration: 0.4, stagger: 0.05, ease: 'power2.out' }
    );
  }

  // Expose remove helper to inline onclick
  (window as any).__removeEnquiryItem = removeItem;

  // Listen to enquiry list changes from other tabs or initGlobal
  window.addEventListener('storage', () => render(getList()));
  window.addEventListener('rcb:list-updated', () => render(getList()));

  // Override clearEnquiry to re-render
  const origClear = (window as any).clearEnquiry;
  (window as any).clearEnquiry = () => {
    origClear?.();
    render(getList());
  };

  // Initial render
  render(getList());
</script>
