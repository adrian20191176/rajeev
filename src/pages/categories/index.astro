---
import SiteFooter from "../../components/SiteFooter.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteScripts from "../../components/SiteScripts.astro";
import { categories, contact, deepGrooveProducts, getCategoryProducts } from "../../data/catalog";
import "../../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Browse Royal Crown Bearings categories including bearings, V-belts, tooth belts, oil seals, housings, and UC bearings."
		/>
		<title>Categories | Royal Crown Bearings</title>
	</head>
	<body>
		<SiteHeader current="Categories" />

		<main>
			<section class="page-hero section-shell">
				<div class="page-hero-copy" data-reveal>
					<p class="eyebrow">Category directory</p>
					<h1>Browse by component family.</h1>
					<p>
						Categories are the top-level way to browse the catalog. Product entries live inside the
						category pages, starting with Deep Groove Ball Bearings.
					</p>
				</div>

				<div class="directory-stats" data-reveal>
					<div>
						<strong>{categories.length}</strong>
						<span>Categories</span>
					</div>
					<div>
						<strong>{deepGrooveProducts.length}</strong>
						<span>Listed products</span>
					</div>
					<div>
						<strong>1</strong>
						<span>Populated category</span>
					</div>
				</div>
			</section>

			<section class="section-shell directory-section" data-filter-scope>
				<div class="directory-toolbar" data-reveal>
					<label class="search-field">
						<span>Search categories</span>
						<input
							type="search"
							placeholder="Try oil seals, UC, V-belts, 6200..."
							autocomplete="off"
							data-filter-input
						/>
					</label>
					<div class="catalog-meta">
						<span data-filter-count>{categories.length} results</span>
						<span>Bearings, belts, seals, housings</span>
					</div>
				</div>

				<div class="category-directory-grid">
					{categories.map((category) => {
						const productCount = getCategoryProducts(category.slug).length;
						const searchText = `${category.name} ${category.summary} ${category.description} ${category.tags.join(" ")}`.toLowerCase();

						return (
							<a class="category-showcase-card category-directory-card" href={`/categories/${category.slug}/`} data-filter-item data-search={searchText} data-reveal>
								<div class="image-placeholder" aria-hidden="true">
									<span>{category.imageLabel}</span>
								</div>
								<div>
									<span class="status-pill">{productCount > 0 ? `${productCount} products` : category.status}</span>
									<h2>{category.name}</h2>
									<p>{category.summary}</p>
								</div>
							</a>
						);
					})}
				</div>

				<p class="empty-state" hidden data-filter-empty>No matching category found.</p>
			</section>

			<section class="section-shell contact-strip" data-reveal>
				<div>
					<p class="eyebrow">Need help matching a product?</p>
					<h2>Send the code, size, or machine requirement.</h2>
				</div>
				<a class="button button-primary" href={contact.whatsapp}>Message on WhatsApp</a>
			</section>
		</main>

		<SiteFooter />
		<SiteScripts />
	</body>
</html>
