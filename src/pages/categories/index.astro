---
import Layout from "../../layouts/Layout.astro";
import NavBar from "../../components/NavBar.astro";
import Footer from "../../components/Footer.astro";
import BearingSVG from "../../components/BearingSVG.astro";
import { CATEGORIES } from "../../data/rcb";

const families = ["All", "Ball Bearings", "Roller Bearings", "Thrust", "Belts", "Seals", "Housings", "Mounted Units"];

const familyMeta: Record<string, { short: string }> = {
  "Ball Bearings":   { short: "Precision ball bearing solutions for radial and combined loads." },
  "Roller Bearings": { short: "Heavy-duty roller elements for maximum radial load capacity." },
  "Thrust":          { short: "Axial load bearings for turntables, steering and cranes." },
  "Belts":           { short: "V-belts and synchronous timing belts for power transmission." },
  "Seals":           { short: "Oil seals to retain lubrication and exclude contamination." },
  "Housings":        { short: "Pillow blocks and flange units for ready-to-mount shaft support." },
  "Mounted Units":   { short: "Insert bearings for UCP, UCF and take-up housing units." },
};

const categoryCount = CATEGORIES.length;
---

<Layout
  title="All Categories — Bearings, Belts & Seals"
  description="Browse all Royal Crown Bearings product categories: deep groove ball bearings, roller bearings, V-belts, oil seals, housings and more. Premium NTN, NSK, FAG, SKF parts in Sri Lanka."
>
  <NavBar slot="navbar" currentPath="/categories" />

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <section class="relative pt-28 pb-16 tech-grid overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 70% 50% at 50% -10%,rgba(0,224,255,0.08),transparent 70%)"></div>

    <div class="max-w-7xl mx-auto px-5 sm:px-6">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 font-mono text-[11px] tracking-[0.2em] uppercase text-chrome-200/50 mb-8 gsap-reveal" aria-label="Breadcrumb">
        <a href="/" class="hover:text-cyan-brand transition-colors">Home</a>
        <span class="text-chrome-200/30">/</span>
        <span class="text-chrome-200/80">Categories</span>
      </nav>

      <div class="flex flex-col lg:flex-row lg:items-end gap-8">
        <div class="flex-1">
          <div class="flex items-center gap-3 font-mono text-[11px] tracking-[0.28em] uppercase mb-4 gsap-reveal">
            <span class="inline-block w-6 h-px bg-cyan-brand"></span>
            <span class="text-cyan-brand">Product Range</span>
          </div>
          <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-chrome-50 leading-[1.05] gsap-reveal">
            All Categories
          </h1>
          <p class="mt-4 text-lg text-chrome-100/70 max-w-xl leading-relaxed gsap-reveal">
            {categoryCount} product categories spanning ball bearings, roller bearings, belts, oil seals, housings, and mounted units — sourced from the world's leading manufacturers.
          </p>
        </div>

        <!-- Quick stats strip -->
        <div class="flex items-center gap-6 gsap-reveal shrink-0">
          {[
            { n: categoryCount, label: "Categories" },
            { n: "12+", label: "Brands" },
            { n: "100+", label: "Products" },
          ].map(({ n, label }) => (
            <div class="text-center">
              <div class="font-display text-2xl font-bold text-chrome-50">{n}</div>
              <div class="font-mono text-[9px] tracking-[0.22em] uppercase text-chrome-200/50 mt-0.5">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Filter tabs ────────────────────────────────────────────────────── -->
  <div class="sticky top-[60px] z-30 border-b hairline bg-ink-900/95 backdrop-blur-md">
    <div class="max-w-7xl mx-auto px-5 sm:px-6">
      <div class="flex items-center gap-1 overflow-x-auto scrollbar-none py-2" id="family-tabs" role="tablist" aria-label="Filter by family">
        {families.map((fam) => (
          <button
            role="tab"
            data-family={fam}
            aria-selected={fam === "All" ? "true" : "false"}
            class="family-tab shrink-0 px-3 py-1.5 rounded-md font-mono text-[10px] tracking-[0.18em] uppercase transition-all whitespace-nowrap"
          >
            {fam}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- ── Category grid ─────────────────────────────────────────────────── -->
  <main class="max-w-7xl mx-auto px-5 sm:px-6 py-12">
    {families.filter(f => f !== "All").map((fam) => {
      const cats = CATEGORIES.filter(c => c.family === fam);
      if (!cats.length) return null;
      return (
        <section class="family-section mb-16" data-family={fam}>
          <div class="flex items-center gap-4 mb-8">
            <div>
              <h2 class="font-display text-xl font-semibold text-chrome-50">{fam}</h2>
              {familyMeta[fam] && (
                <p class="font-mono text-[11px] tracking-[0.14em] text-chrome-200/60 mt-0.5">{familyMeta[fam].short}</p>
              )}
            </div>
            <div class="flex-1 h-px bg-gradient-to-r from-white/10 to-transparent"></div>
            <span class="font-mono text-[10px] tracking-[0.22em] uppercase text-chrome-200/40 border hairline rounded px-2 py-1 shrink-0">
              {cats.length} {cats.length === 1 ? "category" : "categories"}
            </span>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {cats.map((cat) => (
              <a
                href={`/categories/${cat.slug}`}
                class="cat-card group relative chrome-border rounded-xl bg-ink-800/60 p-5 flex flex-col gap-4 hover:bg-ink-800/80 transition-all duration-300 hover:-translate-y-0.5"
              >
                <div class="flex items-center gap-4">
                  <div class="w-14 h-14 shrink-0 rounded-lg border hairline-strong bg-ink-700/60 grid place-items-center overflow-hidden">
                    <BearingSVG type={cat.iconType as any} size={52} />
                  </div>
                  <div class="flex-1 min-w-0">
                    <h3 class="font-display text-[15px] font-semibold text-chrome-50 leading-snug group-hover:text-cyan-brand transition-colors line-clamp-2">
                      {cat.name}
                    </h3>
                    <div class="font-mono text-[9px] tracking-[0.22em] uppercase text-chrome-200/50 mt-1">{cat.family}</div>
                  </div>
                </div>

                <p class="text-sm text-chrome-100/70 leading-relaxed line-clamp-2">{cat.short}</p>

                <div class="flex items-center justify-between mt-auto pt-2 border-t hairline">
                  <span class="font-mono text-[10px] tracking-[0.18em] uppercase text-cyan-brand/70">View Products</span>
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6"
                       stroke-linecap="round" stroke-linejoin="round"
                       class="text-cyan-brand/50 group-hover:text-cyan-brand group-hover:translate-x-0.5 transition-all">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="13,6 19,12 13,18"/>
                  </svg>
                </div>
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </main>

  <!-- ── CTA strip ─────────────────────────────────────────────────────── -->
  <section class="border-t hairline bg-ink-800/40 py-12">
    <div class="max-w-3xl mx-auto px-5 sm:px-6 text-center gsap-cta">
      <div class="font-mono text-[11px] tracking-[0.28em] uppercase text-amber-signal mb-3">Can't find what you need?</div>
      <h2 class="font-display text-2xl sm:text-3xl font-bold text-chrome-50 mb-4">Tell us your specification</h2>
      <p class="text-chrome-100/70 mb-8">Our technical team will source the right bearing or component — even for obsolete or hard-to-find part numbers.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <button onclick="openEnquiryModal([])"
                class="inline-flex items-center justify-center gap-2 font-medium tracking-tight rounded-md transition-all duration-200 px-6 py-3 text-[15px] bg-amber-signal text-ink-900 hover:bg-white hover:shadow-glow-amber btn-shine">
          Send Enquiry
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="13,6 19,12 13,18"/>
          </svg>
        </button>
        <a href="https://wa.me/94766550249" target="_blank" rel="noopener"
           class="inline-flex items-center justify-center gap-2 font-medium tracking-tight rounded-md transition-all duration-200 px-6 py-3 text-[15px] border hairline-strong text-chrome-50 hover:border-cyan-brand/50 hover:text-cyan-brand bg-ink-800/40 btn-shine">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
            <path d="M20.5 3.5A11 11 0 0 0 3.7 17.3L2 22l4.8-1.6A11 11 0 1 0 20.5 3.5z"/>
          </svg>
          WhatsApp Us
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .scrollbar-none { scrollbar-width: none; }
  .scrollbar-none::-webkit-scrollbar { display: none; }
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  .family-tab {
    color: rgba(194,204,219,0.6);
    border: 1px solid transparent;
  }
  .family-tab[aria-selected="true"],
  .family-tab.active {
    color: #00E0FF;
    background: rgba(0,224,255,0.08);
    border-color: rgba(0,224,255,0.20);
  }
  .family-tab:hover:not([aria-selected="true"]) {
    color: rgba(242,246,250,0.9);
    background: rgba(255,255,255,0.04);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // ── Entrance animations ──────────────────────────────────────────────
  const reveals = document.querySelectorAll('.gsap-reveal');
  gsap.fromTo(reveals,
    { opacity: 0, y: 20 },
    { opacity: 1, y: 0, duration: 0.6, stagger: 0.1, ease: 'power2.out', delay: 0.1 }
  );

  ScrollTrigger.batch('.cat-card', {
    onEnter: (els) => gsap.fromTo(els,
      { opacity: 0, y: 24 },
      { opacity: 1, y: 0, duration: 0.5, stagger: 0.07, ease: 'power2.out' }
    ),
    start: 'top 92%',
    once: true,
  });

  const cta = document.querySelector('.gsap-cta');
  if (cta) {
    ScrollTrigger.create({
      trigger: cta,
      start: 'top 88%',
      once: true,
      onEnter: () => gsap.fromTo(cta, { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' }),
    });
  }

  // ── Family filter tabs ───────────────────────────────────────────────
  const tabs     = document.querySelectorAll<HTMLButtonElement>('.family-tab');
  const sections = document.querySelectorAll<HTMLElement>('.family-section');

  function setFilter(family: string) {
    tabs.forEach(tab => {
      const active = tab.dataset.family === family;
      tab.setAttribute('aria-selected', String(active));
      tab.classList.toggle('active', active);
    });

    sections.forEach(sec => {
      const match = family === 'All' || sec.dataset.family === family;
      sec.style.display = match ? '' : 'none';
    });

    // Re-trigger ScrollTrigger so freshly visible cards animate
    ScrollTrigger.refresh();
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => setFilter(tab.dataset.family ?? 'All'));
  });

  // Honour hash on load
  const hash = location.hash.slice(1);
  if (hash && [...tabs].some(t => t.dataset.family === hash)) {
    setFilter(hash);
  }
</script>
