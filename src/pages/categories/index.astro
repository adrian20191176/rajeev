---
import Layout from '../../layouts/Layout.astro';
import BearingVisual from '../../components/BearingVisual.astro';
import { CATEGORIES, PRODUCTS } from '../../data/rcb.js';

const families = ['All', ...new Set(CATEGORIES.map(c => c.family))];
const countMap: Record<string, number> = {};
PRODUCTS.forEach(p => { countMap[p.category] = (countMap[p.category] || 0) + 1; });
---

<Layout title="Product Categories | Royal Crown Bearings" description="Browse all 18 product categories — bearings, V-belts, oil seals and housings from NTN, NSK, FAG, SKF and more." activeNav="categories">

  <section class="relative border-b hairline overflow-hidden">
    <div class="absolute inset-0 tech-grid pointer-events-none"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 md:px-6 pt-10 pb-12 md:pt-16 md:pb-16">
      <div class="font-mono text-[10px] tracking-widest uppercase text-gold/70 mb-3 flex items-center gap-2">
        <a href="/" class="hover:text-gold transition-colors">Home</a>
        <span class="text-chrome-200/30">/</span>
        <span>Categories</span>
      </div>
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-chrome-50 tracking-tight">Product Categories</h1>
      <p class="mt-3 text-chrome-200/70 max-w-2xl text-sm md:text-base leading-relaxed">
        18 categories covering ball bearings, roller bearings, belts, oil seals and housings — sourced from 12 world-class manufacturers.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 md:px-6 py-10 md:py-14">

    <!-- Family filter -->
    <div class="flex flex-wrap gap-2 mb-8" id="family-filters" role="group" aria-label="Filter by family">
      {families.map((f, i) => (
        <button
          data-family={f}
          aria-pressed={i === 0 ? "true" : "false"}
          class="filter-btn font-mono text-[11px] tracking-wider uppercase px-4 py-2 rounded border transition-colors"
        >
          {f}
        </button>
      ))}
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="categories-grid">
      {CATEGORIES.map(cat => (
        <a
          href={`/categories/${cat.slug}`}
          data-family={cat.family}
          class="cat-card group relative flex flex-col rounded-xl border hairline bg-ink-800/60 p-5 hover:border-gold/40 hover:-translate-y-px transition-all duration-200"
          style="box-shadow: var(--shadow-card)"
        >
          <div class="flex items-start gap-4">
            <div class="shrink-0 w-16 h-16 opacity-90 group-hover:opacity-100 transition-opacity">
              <BearingVisual iconType={cat.iconType} size={64} />
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-mono text-[9px] tracking-widest uppercase text-gold/60 mb-1">{cat.family}</div>
              <h2 class="font-display text-sm font-semibold text-chrome-50 leading-snug group-hover:text-gold transition-colors">{cat.name}</h2>
            </div>
          </div>
          <p class="mt-3 text-xs text-chrome-200/60 leading-relaxed flex-1">{cat.short}</p>
          <div class="mt-4 pt-3 border-t hairline flex items-center justify-between">
            <span class="font-mono text-[10px] tracking-widest uppercase text-chrome-200/40">
              {countMap[cat.slug] || 0} products
            </span>
            <span class="font-mono text-[10px] tracking-widest uppercase text-gold/60 group-hover:text-gold flex items-center gap-1 transition-colors">
              View
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="group-hover:translate-x-0.5 transition-transform"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12,5 19,12 12,19"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>

  </section>
</Layout>

<style>
  .filter-btn {
    border-color: rgba(167,169,172,0.2);
    color: rgba(167,169,172,0.7);
    background: transparent;
    cursor: pointer;
  }
  .filter-btn:hover {
    border-color: rgba(212,175,55,0.4);
    color: #f5f6f8;
  }
  .filter-btn[aria-pressed="true"] {
    border-color: rgba(212,175,55,0.6);
    background: rgba(212,175,55,0.1);
    color: #d4af37;
  }
  .cat-card[data-hidden] {
    display: none;
  }
</style>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.cat-card');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const family = btn.dataset.family!;
      btns.forEach(b => b.setAttribute('aria-pressed', 'false'));
      btn.setAttribute('aria-pressed', 'true');
      cards.forEach(card => {
        const show = family === 'All' || card.dataset.family === family;
        card.toggleAttribute('data-hidden', !show);
      });
    });
  });
</script>
