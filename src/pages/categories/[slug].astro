---
import SiteFooter from "../../components/SiteFooter.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteScripts from "../../components/SiteScripts.astro";
import { categories, contact, getCategoryProducts } from "../../data/catalog";
import "../../styles/global.css";

export function getStaticPaths() {
	return categories.map((category) => ({
		params: { slug: category.slug },
		props: { category },
	}));
}

const { category } = Astro.props;
const products = getCategoryProducts(category.slug);
const hasProducts = products.length > 0;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={`${category.name} from Royal Crown Bearings. ${category.summary}`} />
		<title>{category.name} | Royal Crown Bearings</title>
	</head>
	<body>
		<SiteHeader current="Categories" />

		<main>
			<section class="category-hero section-shell">
				<div class="category-hero-copy" data-reveal>
					<a class="breadcrumb-link" href="/categories/">Categories</a>
					<p class="eyebrow">{hasProducts ? "Product category" : "Category"}</p>
					<h1>{category.name}</h1>
					<p>{category.description}</p>
					<div class="hero-actions">
						<a class="button button-primary" href={contact.whatsapp}>Check availability</a>
						<a class="button button-secondary" href="/categories/">All categories</a>
					</div>
				</div>

				<div class="category-hero-card" data-reveal>
					<div class="image-placeholder large-placeholder" aria-hidden="true">
						<span>{category.imageLabel}</span>
					</div>
					<div class="category-meta-list">
						<div>
							<strong>{products.length}</strong>
							<span>Products listed</span>
						</div>
						<div>
							<strong>{category.status}</strong>
							<span>Status</span>
						</div>
					</div>
				</div>
			</section>

			{hasProducts ? (
				<section class="section-shell product-directory" data-filter-scope>
					<div class="directory-toolbar" data-reveal>
						<label class="search-field">
							<span>Search products in this category</span>
							<input
								type="search"
								placeholder="Try 6205-2RS, 6000-ZZ, C3..."
								autocomplete="off"
								data-query-param="q"
								data-filter-input
							/>
						</label>
						<div class="catalog-meta">
							<span data-filter-count>{products.length} results</span>
							<span>Search by code, series, or variant</span>
						</div>
					</div>

					<div class="product-directory-grid">
						{products.map((product) => (
							<article class="product-card" data-filter-item data-search={product.searchText} data-reveal>
								<div class="product-image-placeholder" aria-hidden="true">
									<span>{product.imageLabel}</span>
								</div>
								<div class="product-card-body">
									<span class="status-pill">{product.series}</span>
									<h2>{product.sku}</h2>
									<p>{product.description}</p>
									<dl>
										<div>
											<dt>Variant</dt>
											<dd>{product.variant}</dd>
										</div>
										<div>
											<dt>Category</dt>
											<dd>Deep Groove</dd>
										</div>
									</dl>
								</div>
							</article>
						))}
					</div>

					<p class="empty-state" hidden data-filter-empty>No matching product found.</p>
				</section>
			) : (
				<section class="section-shell coming-soon-panel" data-reveal>
					<div class="section-heading compact">
						<p class="eyebrow">Catalog coming soon</p>
						<h2>Products for this category are not listed yet.</h2>
						<p>
							For current stock, share the category name, required size, or machine details with
							the team.
						</p>
					</div>
					<div class="section-actions">
						<a class="button button-primary" href={contact.whatsapp}>Ask about {category.shortName}</a>
						<a class="button button-secondary" href={contact.phoneHref}>{contact.phone}</a>
					</div>
				</section>
			)}
		</main>

		<SiteFooter />
		<SiteScripts />
	</body>
</html>
