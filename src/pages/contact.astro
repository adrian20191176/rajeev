---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import { getBusiness } from '../data/rcb.js';

const BUSINESS = await getBusiness();
---

<Layout title="Contact Us | Royal Crown Bearings" description="Get in touch with Royal Crown Bearings — phone, WhatsApp, email or our online enquiry form." activeNav="contact">

  <!-- Header -->
  <section class="relative border-b hairline overflow-hidden">
    <div class="absolute inset-0 tech-grid pointer-events-none"></div>
    <div class="absolute inset-0 spot pointer-events-none"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 md:px-6 pt-10 pb-14 md:pt-20 md:pb-20">
      <div class="font-mono text-[10px] tracking-widest uppercase text-gold/70 mb-3 flex items-center gap-2">
        <a href="/" class="hover:text-gold transition-colors">Home</a>
        <span class="text-chrome-200/30">/</span>
        <span>Contact</span>
      </div>
      <h1 data-hero-step data-split-words class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-chrome-50 tracking-tight">
        Get in Touch
      </h1>
      <p data-hero-step class="mt-3 text-chrome-200/70 max-w-xl text-sm md:text-base leading-relaxed">
        We're available 24/7 to assist with product availability, pricing, and technical questions.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 md:px-6 py-12 md:py-18">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12">

      <!-- Contact info -->
      <div class="lg:col-span-2 flex flex-col gap-6">

        <!-- Quick contact cards -->
        <div data-reveal data-tilt data-tilt-max="3" class="rounded-xl border hairline bg-ink-800/60 p-6" style="box-shadow: var(--shadow-card)">
          <div class="font-mono text-[10px] tracking-widest uppercase text-chrome-200/50 mb-4">Direct Contact</div>
          <div class="flex flex-col gap-5">
            <a href={`tel:${BUSINESS.phone.replace(/\s/g,'')}`}
               class="flex items-center gap-4 group">
              <div class="w-10 h-10 rounded-lg bg-gold/10 border border-gold/20 flex items-center justify-center shrink-0">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4h4l2 5-3 2a12 12 0 0 0 5 5l2-3 5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"/></svg>
              </div>
              <div>
                <div class="font-mono text-[9px] tracking-widest uppercase text-chrome-200/40 mb-0.5">Phone</div>
                <div class="text-sm font-medium text-chrome-50 group-hover:text-gold transition-colors">{BUSINESS.phone}</div>
              </div>
            </a>
            <a href={`https://wa.me/${BUSINESS.whatsapp}`} target="_blank" rel="noopener noreferrer"
               class="flex items-center gap-4 group">
              <div class="w-10 h-10 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center shrink-0">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4ade80"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.557 4.126 1.533 5.862L.057 23.5l5.784-1.517A11.944 11.944 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.816 9.816 0 0 1-5.001-1.372l-.358-.213-3.726.977.995-3.633-.233-.373A9.818 9.818 0 0 1 2.182 12C2.182 6.573 6.573 2.182 12 2.182S21.818 6.573 21.818 12 17.427 21.818 12 21.818z"/></svg>
              </div>
              <div>
                <div class="font-mono text-[9px] tracking-widest uppercase text-chrome-200/40 mb-0.5">WhatsApp</div>
                <div class="text-sm font-medium text-chrome-50 group-hover:text-emerald-400 transition-colors">+{BUSINESS.whatsapp}</div>
              </div>
            </a>
            <a href={`mailto:${BUSINESS.email}`}
               class="flex items-center gap-4 group">
              <div class="w-10 h-10 rounded-lg bg-gold/10 border border-gold/20 flex items-center justify-center shrink-0">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><polyline points="3,7 12,13 21,7"/></svg>
              </div>
              <div>
                <div class="font-mono text-[9px] tracking-widest uppercase text-chrome-200/40 mb-0.5">Email</div>
                <div class="text-sm font-medium text-chrome-50 group-hover:text-gold transition-colors break-all">{BUSINESS.email}</div>
              </div>
            </a>
          </div>
        </div>

        <!-- Service hours -->
        <div data-reveal class="rounded-xl border hairline bg-ink-800/60 p-6" style="box-shadow: var(--shadow-card)">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
            <div class="font-mono text-[10px] tracking-widest uppercase text-emerald-400/80">Currently Open</div>
          </div>
          <div class="font-display text-lg font-semibold text-chrome-50">24/7 Service Hours</div>
          <p class="mt-1 text-sm text-chrome-200/50">We're available around the clock to assist with enquiries and urgent orders.</p>
        </div>

        <!-- WhatsApp CTA -->
        <a href={`https://wa.me/${BUSINESS.whatsapp}?text=${encodeURIComponent('Hi Royal Crown Bearings, I have an enquiry.')}`}
           target="_blank"
           rel="noopener noreferrer"
           data-reveal
           class="btn-shine flex items-center justify-center gap-3 px-6 py-4 rounded-xl bg-emerald-600/90 hover:bg-emerald-500 text-white font-medium text-sm transition-all">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.557 4.126 1.533 5.862L.057 23.5l5.784-1.517A11.944 11.944 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.816 9.816 0 0 1-5.001-1.372l-.358-.213-3.726.977.995-3.633-.233-.373A9.818 9.818 0 0 1 2.182 12C2.182 6.573 6.573 2.182 12 2.182S21.818 6.573 21.818 12 17.427 21.818 12 21.818z"/></svg>
          Chat on WhatsApp Now
        </a>

      </div>

      <!-- Enquiry form -->
      <div class="lg:col-span-3">
        <div data-reveal class="rounded-xl border hairline bg-ink-800/60 p-6 md:p-8" style="box-shadow: var(--shadow-card)">
          <div class="font-mono text-[10px] tracking-widest uppercase text-chrome-200/50 mb-1">Send a Message</div>
          <h2 class="font-display text-xl font-semibold text-chrome-50 mb-6">Enquiry Form</h2>

          <form id="contact-form" class="flex flex-col gap-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div class="flex flex-col gap-1.5">
                <label class="font-mono text-[10px] tracking-widest uppercase text-chrome-200/60">Full Name *</label>
                <input name="name" required type="text" placeholder="Your full name"
                  class="px-4 py-3 rounded-lg border hairline bg-ink-700/50 text-chrome-50 text-sm placeholder:text-chrome-200/25 focus:outline-none focus:border-gold/40 transition-colors" />
              </div>
              <div class="flex flex-col gap-1.5">
                <label class="font-mono text-[10px] tracking-widest uppercase text-chrome-200/60">Phone Number *</label>
                <input name="phone" required type="tel" placeholder="+94 7XX XXX XXX"
                  class="px-4 py-3 rounded-lg border hairline bg-ink-700/50 text-chrome-50 text-sm placeholder:text-chrome-200/25 focus:outline-none focus:border-gold/40 transition-colors" />
              </div>
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="font-mono text-[10px] tracking-widest uppercase text-chrome-200/60">Email Address</label>
              <input name="email" type="email" placeholder="you@example.com"
                class="px-4 py-3 rounded-lg border hairline bg-ink-700/50 text-chrome-50 text-sm placeholder:text-chrome-200/25 focus:outline-none focus:border-gold/40 transition-colors" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="font-mono text-[10px] tracking-widest uppercase text-chrome-200/60">Parts / Products Required *</label>
              <input name="parts" required type="text" placeholder="e.g. 6205-2RS × 10, 6208-ZZ × 5"
                class="px-4 py-3 rounded-lg border hairline bg-ink-700/50 text-chrome-50 text-sm placeholder:text-chrome-200/25 focus:outline-none focus:border-gold/40 transition-colors" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="font-mono text-[10px] tracking-widest uppercase text-chrome-200/60">Additional Message</label>
              <textarea name="message" rows="4" placeholder="Urgency, delivery requirements, etc."
                class="px-4 py-3 rounded-lg border hairline bg-ink-700/50 text-chrome-50 text-sm placeholder:text-chrome-200/25 focus:outline-none focus:border-gold/40 transition-colors resize-none"></textarea>
            </div>
            <button type="submit" class="btn-shine self-start inline-flex items-center gap-2 px-6 py-3.5 rounded-md bg-gold text-ink-900 font-medium text-sm hover:shadow-glow-cyan transition-all">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22,2 15,22 11,13 2,9 22,2"/></svg>
              Send via WhatsApp
            </button>
          </form>
        </div>
      </div>

    </div>
  </section>

</Layout>

<script is:inline define:vars={{ waNumber: BUSINESS.whatsapp }}>
  document.getElementById('contact-form')?.addEventListener('submit', e => {
    e.preventDefault();
    const fd = new FormData(e.target);
    const lines = [
      `New enquiry from ${fd.get('name')}`,
      `Phone: ${fd.get('phone')}`,
      fd.get('email') ? `Email: ${fd.get('email')}` : null,
      ``,
      `Parts required: ${fd.get('parts')}`,
      fd.get('message') ? `Message: ${fd.get('message')}` : null,
    ].filter(l => l !== null);
    const url = `https://wa.me/${waNumber}?text=${encodeURIComponent(lines.join('\n'))}`;
    window.open(url, '_blank', 'noopener');
    window.showToast?.({ title: 'Opening WhatsApp…', tone: 'success' });
  });
</script>
