---
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import { BUSINESS } from "../data/rcb";

const contactCards = [
  {
    label:   "Phone",
    value:   BUSINESS.phone,
    href:    `tel:${BUSINESS.phone.replace(/\s/g, '')}`,
    note:    "24/7 — call anytime",
    color:   "cyan",
    icon: `<path d="M5 4h4l2 5-3 2a12 12 0 0 0 5 5l2-3 5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    label:   "WhatsApp",
    value:   `wa.me/${BUSINESS.whatsapp.replace('+','')}`,
    href:    `https://wa.me/${BUSINESS.whatsapp.replace('+','')}`,
    note:    "Fastest response channel",
    color:   "amber",
    icon: `<path d="M20.5 3.5A11 11 0 0 0 3.7 17.3L2 22l4.8-1.6A11 11 0 1 0 20.5 3.5z" fill="currentColor"/>`,
    external: true,
  },
  {
    label:   "Email",
    value:   BUSINESS.email,
    href:    `mailto:${BUSINESS.email}`,
    note:    "Reply within 1 business hour",
    color:   "cyan",
    icon: `<rect x="3" y="5" width="18" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><polyline points="3,7 12,13 21,7" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
  {
    label:   "Service Hours",
    value:   "24/7 — Every Day",
    href:    null,
    note:    "No public holidays",
    color:   "emerald",
    icon: `<circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1.6"/><polyline points="12 6 12 12 16 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
];

const faqs = [
  {
    q: "Do you ship island-wide in Sri Lanka?",
    a: "Yes — we deliver to all provinces. Orders placed by noon are dispatched same day for major cities. Remote areas may take 1–2 additional business days.",
  },
  {
    q: "Can you source obsolete or hard-to-find bearing numbers?",
    a: "Absolutely. Send us the bearing number, manufacturer (if known), and application details via WhatsApp or email. Our team will locate the part or a suitable cross-reference.",
  },
  {
    q: "Do you supply single pieces or bulk orders only?",
    a: "Both. We serve everything from a single bearing for a home workshop to bulk pallet orders for manufacturing facilities. Quantity pricing is available.",
  },
  {
    q: "Which brands do you stock?",
    a: "We carry NTN, NSK, NACHI, KOYO, FAG, SKF, TIMKEN, FYH, ASAHI, FBJ, MITSUBOSHI and FENNER. We can also source other brands on request.",
  },
  {
    q: "How do I confirm a part is compatible with my machine?",
    a: "Provide the existing part code or the shaft diameter, outer diameter, and width (bore × OD × width in mm) and we'll confirm compatibility before you order.",
  },
];
---

<Layout
  title="Contact Royal Crown Bearings — Sri Lanka"
  description="Contact Royal Crown Bearings Sri Lanka by phone, WhatsApp or email. 24/7 service for bearings, V-belts, oil seals and industrial components. Call +94 766 550 249."
>
  <NavBar slot="navbar" currentPath="/contact" />

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <section class="relative pt-28 pb-16 tech-grid overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 60% 50% at 50% -10%,rgba(0,224,255,0.08),transparent 70%)"></div>

    <div class="max-w-7xl mx-auto px-5 sm:px-6 relative z-10">
      <nav class="flex items-center gap-2 font-mono text-[11px] tracking-[0.2em] uppercase text-chrome-200/50 mb-10 gsap-reveal" aria-label="Breadcrumb">
        <a href="/" class="hover:text-cyan-brand transition-colors">Home</a>
        <span class="text-chrome-200/30">/</span>
        <span class="text-chrome-200/80">Contact Us</span>
      </nav>

      <div class="max-w-3xl">
        <div class="flex items-center gap-3 font-mono text-[11px] tracking-[0.28em] uppercase mb-5 gsap-reveal">
          <span class="inline-block w-6 h-px bg-cyan-brand"></span>
          <span class="text-cyan-brand">Get in Touch</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-bold tracking-tight text-chrome-50 leading-[1.08] gsap-reveal">
          We're here<br class="hidden sm:block"/> whenever you need us
        </h1>
        <p class="mt-5 text-lg text-chrome-100/70 leading-relaxed gsap-reveal">
          Whether you're chasing a hard-to-find bearing number or need a bulk quote, our team responds fast — 24 hours a day, 7 days a week.
        </p>

        <!-- Live status indicator -->
        <div class="mt-6 inline-flex items-center gap-2 font-mono text-[11px] tracking-[0.22em] uppercase text-emerald-400 gsap-reveal">
          <span class="w-2 h-2 rounded-full bg-emerald-400 live-dot"></span>
          Available now
        </div>
      </div>
    </div>
  </section>

  <!-- ── Contact cards ─────────────────────────────────────────────────── -->
  <section class="max-w-7xl mx-auto px-5 sm:px-6 py-14">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {contactCards.map((card) => (
        <div class={`contact-card chrome-border rounded-xl bg-ink-800/60 p-6 flex flex-col gap-4 hover:bg-ink-800/80 transition-all duration-300 hover:-translate-y-0.5 ${card.href ? 'cursor-pointer' : ''}`}
             onclick={card.href ? `window.open('${card.href}', '${card.external ? '_blank' : '_self'}')` : undefined}>
          <div class={`w-10 h-10 rounded-lg border grid place-items-center shrink-0 ${
            card.color === 'amber'   ? 'border-amber-signal/30 bg-amber-signal/10 text-amber-signal' :
            card.color === 'emerald' ? 'border-emerald-400/30 bg-emerald-400/5 text-emerald-400' :
                                       'border-cyan-brand/30 bg-cyan-brand/10 text-cyan-brand'
          }`}>
            <svg viewBox="0 0 24 24" width="18" height="18">{card.icon && <Fragment set:html={card.icon} />}</svg>
          </div>

          <div>
            <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-chrome-200/50 mb-1.5">{card.label}</div>
            {card.href ? (
              <a href={card.href}
                 target={card.external ? '_blank' : undefined}
                 rel={card.external ? 'noopener noreferrer' : undefined}
                 class={`font-display text-base font-semibold transition-colors break-all ${
                   card.color === 'amber' ? 'text-amber-signal hover:text-amber-signal/80' :
                   card.color === 'emerald' ? 'text-emerald-400' :
                                              'text-chrome-50 hover:text-cyan-brand'
                 }`}
                 onclick="event.stopPropagation()">
                {card.value}
              </a>
            ) : (
              <div class="font-display text-base font-semibold text-emerald-400">{card.value}</div>
            )}
            <div class="font-mono text-[10px] tracking-[0.16em] text-chrome-200/40 mt-1">{card.note}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Main content: form + map placeholder ───────────────────────────── -->
  <section class="max-w-7xl mx-auto px-5 sm:px-6 pb-20 grid grid-cols-1 lg:grid-cols-5 gap-10">
    <!-- Enquiry form -->
    <div class="lg:col-span-3 form-panel">
      <div class="chrome-border rounded-2xl bg-ink-800/60 p-6 sm:p-8">
        <div class="mb-6">
          <div class="flex items-center gap-3 font-mono text-[11px] tracking-[0.28em] uppercase mb-2">
            <span class="inline-block w-6 h-px bg-amber-signal"></span>
            <span class="text-amber-signal">Direct Enquiry</span>
          </div>
          <h2 class="font-display text-2xl font-semibold text-chrome-50">Send us a message</h2>
          <p class="text-sm text-chrome-100/60 mt-1">Our team typically replies within 1 business hour.</p>
        </div>

        <form id="contact-form" novalidate class="flex flex-col gap-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <label class="block">
              <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-chrome-200/70 mb-1.5">Full Name *</div>
              <input type="text" name="name" required placeholder="Nuwan Perera"
                     class="w-full px-3 py-2.5 rounded-md border border-white/10 bg-ink-900/70 text-chrome-50 text-sm placeholder-chrome-200/30 focus:border-cyan-brand/60 outline-none transition-colors" />
            </label>
            <label class="block">
              <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-chrome-200/70 mb-1.5">Phone / WhatsApp *</div>
              <input type="tel" name="phone" required placeholder="+94 7X XXX XXXX"
                     class="w-full px-3 py-2.5 rounded-md border border-white/10 bg-ink-900/70 text-chrome-50 text-sm placeholder-chrome-200/30 focus:border-cyan-brand/60 outline-none transition-colors" />
            </label>
          </div>

          <label class="block">
            <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-chrome-200/70 mb-1.5">Email *</div>
            <input type="email" name="email" required placeholder="you@example.com"
                   class="w-full px-3 py-2.5 rounded-md border border-white/10 bg-ink-900/70 text-chrome-50 text-sm placeholder-chrome-200/30 focus:border-cyan-brand/60 outline-none transition-colors" />
          </label>

          <label class="block">
            <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-chrome-200/70 mb-1.5">Subject</div>
            <select name="subject"
                    class="w-full px-3 py-2.5 rounded-md border border-white/10 bg-ink-900/70 text-chrome-50 text-sm focus:border-cyan-brand/60 outline-none transition-colors cursor-pointer">
              <option value="product-enquiry">Product Enquiry</option>
              <option value="bulk-order">Bulk / Wholesale Order</option>
              <option value="sourcing">Source a specific part</option>
              <option value="technical">Technical Question</option>
              <option value="other">Other</option>
            </select>
          </label>

          <label class="block">
            <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-chrome-200/70 mb-1.5">Message *</div>
            <textarea name="message" rows="5" required
                      placeholder="Part code, bore × OD × width, quantities, urgency, delivery location…"
                      class="w-full px-3 py-2.5 rounded-md border border-white/10 bg-ink-900/70 text-chrome-50 text-sm placeholder-chrome-200/30 focus:border-cyan-brand/60 outline-none resize-none transition-colors"></textarea>
          </label>

          <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 pt-2">
            <p class="text-[11px] text-chrome-200/50 font-mono tracking-[0.06em]">
              * Required fields. We'll only use your info to respond.
            </p>
            <button type="submit"
                    class="inline-flex items-center gap-2 font-medium tracking-tight rounded-md transition-all duration-200 px-5 py-3 text-sm bg-amber-signal text-ink-900 hover:bg-white hover:shadow-glow-amber btn-shine shrink-0">
              <span id="submit-label">Send Message</span>
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="13,6 19,12 13,18"/>
              </svg>
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Side info -->
    <div class="lg:col-span-2 flex flex-col gap-5 info-panel">
      <!-- Quick contact -->
      <div class="chrome-border rounded-xl bg-ink-800/60 p-6">
        <div class="font-mono text-[10px] tracking-[0.28em] uppercase text-chrome-200/50 mb-4">Quick Contact</div>
        <div class="flex flex-col gap-3">
          <a href="https://wa.me/94766550249" target="_blank" rel="noopener"
             class="flex items-center gap-3 p-3 rounded-lg border border-amber-signal/20 bg-amber-signal/5 hover:bg-amber-signal/10 transition-colors group">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="#FFB347">
              <path d="M20.5 3.5A11 11 0 0 0 3.7 17.3L2 22l4.8-1.6A11 11 0 1 0 20.5 3.5z"/>
            </svg>
            <div>
              <div class="font-mono text-[10px] tracking-[0.18em] uppercase text-amber-signal">WhatsApp</div>
              <div class="text-sm text-chrome-50 group-hover:text-amber-signal transition-colors">{BUSINESS.phone}</div>
            </div>
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="ml-auto text-amber-signal/50 group-hover:translate-x-0.5 transition-transform">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="13,6 19,12 13,18"/>
            </svg>
          </a>
          <a href={`tel:${BUSINESS.phone.replace(/\s/g,'')}`}
             class="flex items-center gap-3 p-3 rounded-lg border border-cyan-brand/20 bg-cyan-brand/5 hover:bg-cyan-brand/10 transition-colors group">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#00E0FF" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 4h4l2 5-3 2a12 12 0 0 0 5 5l2-3 5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"/>
            </svg>
            <div>
              <div class="font-mono text-[10px] tracking-[0.18em] uppercase text-cyan-brand">Call Direct</div>
              <div class="text-sm text-chrome-50 group-hover:text-cyan-brand transition-colors">{BUSINESS.phone}</div>
            </div>
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="ml-auto text-cyan-brand/50 group-hover:translate-x-0.5 transition-transform">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="13,6 19,12 13,18"/>
            </svg>
          </a>
          <a href={`mailto:${BUSINESS.email}`}
             class="flex items-center gap-3 p-3 rounded-lg border border-white/8 bg-ink-700/40 hover:bg-ink-700/60 transition-colors group">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="rgba(194,204,219,0.8)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2"/><polyline points="3,7 12,13 21,7"/>
            </svg>
            <div class="min-w-0">
              <div class="font-mono text-[10px] tracking-[0.18em] uppercase text-chrome-200/60">Email</div>
              <div class="text-sm text-chrome-100 group-hover:text-chrome-50 transition-colors truncate">{BUSINESS.email}</div>
            </div>
          </a>
        </div>
      </div>

      <!-- Response promise -->
      <div class="chrome-border rounded-xl bg-ink-800/60 p-6">
        <div class="font-mono text-[10px] tracking-[0.28em] uppercase text-chrome-200/50 mb-4">Our Promise</div>
        <div class="flex flex-col gap-3">
          {[
            ["WhatsApp response", "< 30 minutes"],
            ["Email response",    "< 1 business hour"],
            ["Phone",             "Answered 24/7"],
            ["Order processing",  "Same day dispatch"],
          ].map(([label, val]) => (
            <div class="flex items-center justify-between py-2 border-b hairline last:border-0">
              <span class="text-sm text-chrome-100/70">{label}</span>
              <span class="font-mono text-[11px] text-cyan-brand">{val}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── FAQ ───────────────────────────────────────────────────────────── -->
  <section class="border-t hairline bg-ink-800/20 py-20">
    <div class="max-w-3xl mx-auto px-5 sm:px-6">
      <div class="text-center mb-12 faq-header">
        <div class="flex items-center justify-center gap-3 font-mono text-[11px] tracking-[0.28em] uppercase mb-4">
          <span class="inline-block w-6 h-px bg-cyan-brand"></span>
          <span class="text-cyan-brand">FAQ</span>
          <span class="inline-block w-6 h-px bg-cyan-brand"></span>
        </div>
        <h2 class="font-display text-2xl sm:text-3xl font-bold text-chrome-50">Common Questions</h2>
      </div>

      <div class="flex flex-col gap-3" id="faq-list">
        {faqs.map((faq, i) => (
          <details class="faq-item chrome-border rounded-xl bg-ink-800/60 group" data-i={i}>
            <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer list-none select-none">
              <span class="font-display text-[15px] font-medium text-chrome-50 leading-snug">{faq.q}</span>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"
                   class="shrink-0 text-cyan-brand/60 group-open:rotate-45 transition-transform duration-300">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </summary>
            <div class="px-5 pb-5">
              <p class="text-sm text-chrome-100/70 leading-relaxed">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Hero
  gsap.fromTo('.gsap-reveal',
    { opacity: 0, y: 20 },
    { opacity: 1, y: 0, duration: 0.6, stagger: 0.1, ease: 'power2.out', delay: 0.1 }
  );

  // Contact cards
  ScrollTrigger.batch('.contact-card', {
    onEnter: (els) => gsap.fromTo(els,
      { opacity: 0, y: 24 },
      { opacity: 1, y: 0, duration: 0.5, stagger: 0.09, ease: 'power2.out' }
    ),
    start: 'top 90%',
    once: true,
  });

  // Form + info panels
  ScrollTrigger.create({
    trigger: '.form-panel',
    start: 'top 88%',
    once: true,
    onEnter: () => {
      gsap.fromTo('.form-panel',  { opacity: 0, x: -24 }, { opacity: 1, x: 0, duration: 0.65, ease: 'power2.out' });
      gsap.fromTo('.info-panel',  { opacity: 0, x:  24 }, { opacity: 1, x: 0, duration: 0.65, ease: 'power2.out', delay: 0.1 });
    },
  });

  // FAQ items
  ScrollTrigger.batch('.faq-header, .faq-item', {
    onEnter: (els) => gsap.fromTo(els,
      { opacity: 0, y: 18 },
      { opacity: 1, y: 0, duration: 0.45, stagger: 0.07, ease: 'power2.out' }
    ),
    start: 'top 90%',
    once: true,
  });

  // Contact form submission
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const label = document.getElementById('submit-label');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) { form.reportValidity(); return; }
    if (label) label.textContent = 'Sending…';

    await new Promise(r => setTimeout(r, 900 + Math.random() * 600));

    if (Math.random() > 0.05) {
      if (label) label.textContent = 'Sent ✓';
      (window as any).showToast?.('Message received — we\'ll reply within 1 hour.', 'success');
      form.reset();
      setTimeout(() => { if (label) label.textContent = 'Send Message'; }, 3000);
    } else {
      if (label) label.textContent = 'Send Message';
      (window as any).showToast?.('Something went wrong. Please try WhatsApp instead.', 'error');
    }
  });
</script>
