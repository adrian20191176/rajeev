---
import Layout from '../layouts/Layout.astro';
import { BUSINESS, BRANDS } from '../data/rcb.js';
---

<Layout title="About Us | Royal Crown Bearings" description="Learn about Royal Crown Bearings — Sri Lanka's trusted supplier of bearings, V-belts, oil seals and industrial components." activeNav="about">

  <!-- Hero -->
  <section class="relative border-b hairline overflow-hidden">
    <div class="absolute inset-0 tech-grid pointer-events-none"></div>
    <div class="absolute inset-0 spot pointer-events-none"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 md:px-6 pt-10 pb-14 md:pt-20 md:pb-20">
      <div class="font-mono text-[10px] tracking-widest uppercase text-gold/70 mb-3 flex items-center gap-2">
        <a href="/" class="hover:text-gold transition-colors">Home</a>
        <span class="text-chrome-200/30">/</span>
        <span>About Us</span>
      </div>
      <div class="max-w-3xl">
        <div data-hero-step data-eyebrow class="flex items-center gap-2 font-mono text-[11px] tracking-widest uppercase text-gold mb-4">
          <span class="inline-block w-6 h-px bg-gold"></span>Royal Crown Bearings · Est. {BUSINESS.founded}
        </div>
        <h1 data-hero-step data-split-words class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-chrome-50 tracking-tight leading-tight">
          Sri Lanka's Trusted<br/>
          <span class="text-gold">Bearing Specialist</span>
        </h1>
        <p data-hero-step class="mt-5 text-chrome-200/70 text-base md:text-lg leading-relaxed max-w-2xl">
          Royal Crown Bearings supplies premium bearings, V-belts, oil seals and industrial components to vehicle workshops, machinery manufacturers, construction companies and industrial facilities across Sri Lanka.
        </p>
      </div>
    </div>
  </section>

  <!-- Mission + Vision -->
  <section class="max-w-7xl mx-auto px-4 md:px-6 py-12 md:py-18">
    <div data-reveal-group data-reveal-stagger="0.1" class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div data-reveal-item data-tilt data-tilt-max="5" class="rounded-xl border hairline bg-ink-800/60 p-6 md:p-8" style="box-shadow: var(--shadow-card)">
        <div class="w-10 h-10 rounded-lg bg-gold/10 border border-gold/20 flex items-center justify-center mb-5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
        </div>
        <div class="font-mono text-[10px] tracking-widest uppercase text-gold/60 mb-2">Our Mission</div>
        <p class="text-chrome-100/80 leading-relaxed">{BUSINESS.mission}</p>
      </div>
      <div data-reveal-item data-tilt data-tilt-max="5" class="rounded-xl border hairline bg-ink-800/60 p-6 md:p-8" style="box-shadow: var(--shadow-card)">
        <div class="w-10 h-10 rounded-lg bg-gold/10 border border-gold/20 flex items-center justify-center mb-5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        </div>
        <div class="font-mono text-[10px] tracking-widest uppercase text-gold/60 mb-2">Our Vision</div>
        <p class="text-chrome-100/80 leading-relaxed">{BUSINESS.vision}</p>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="border-t hairline">
    <div class="max-w-7xl mx-auto px-4 md:px-6 py-12 md:py-16">
      <div class="text-center mb-10">
        <div data-reveal class="font-mono text-[10px] tracking-widest uppercase text-gold/60 mb-2">What We Stand For</div>
        <h2 data-reveal data-split-words data-split-scroll="1" class="font-display text-2xl md:text-3xl font-bold text-chrome-50">Our Core Values</h2>
      </div>
      <div data-reveal-group data-reveal-stagger="0.07" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
        {BUSINESS.values.map((value, i) => {
          const icons = [
            '<circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>',
            '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
            '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
            '<path d="M12 22V12"/><path d="m17 7-5-5-5 5"/><rect x="2" y="17" width="20" height="5" rx="1"/>',
            '<polyline points="23,6 13.5,15.5 8.5,10.5 1,18"/><polyline points="17,6 23,6 23,12"/>',
          ];
          return (
            <div data-reveal-item data-tilt data-tilt-max="6" class="flex flex-col items-center text-center rounded-xl border hairline bg-ink-800/60 p-6" style="box-shadow: var(--shadow-card)">
              <div class="w-10 h-10 rounded-lg bg-gold/10 border border-gold/20 flex items-center justify-center mb-4">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={icons[i % icons.length]}></svg>
              </div>
              <div class="font-display text-sm font-semibold text-chrome-50">{value}</div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Brands we carry -->
  <section class="border-t hairline">
    <div class="max-w-7xl mx-auto px-4 md:px-6 py-12 md:py-16">
      <div class="text-center mb-10">
        <div data-reveal class="font-mono text-[10px] tracking-widest uppercase text-gold/60 mb-2">Official Stockist</div>
        <h2 data-reveal data-split-words data-split-scroll="1" class="font-display text-2xl md:text-3xl font-bold text-chrome-50">Brands We Carry</h2>
        <p data-reveal class="mt-2 text-chrome-200/50 text-sm max-w-xl mx-auto">Authorised stockist of {BRANDS.length} world-class bearing and power-transmission brands.</p>
      </div>
      <div data-reveal-group data-reveal-stagger="0.05" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-px bg-white/5 rounded-lg overflow-hidden border hairline-strong">
        {BRANDS.map(b => (
          <div data-reveal-item class="bg-ink-700 hover:bg-ink-600 transition-colors p-5 sm:p-6 text-center group flex flex-col items-center justify-center min-h-[152px] sm:min-h-[168px]">
            <div class="h-[104px] sm:h-28 w-full flex items-center justify-center">
              <img
                src={b.logo}
                alt={`${b.name} logo`}
                loading="lazy"
                class={`brand-logo ${b.name === "INA" ? "brand-logo-ina" : ""}`}
              />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t hairline">
    <div class="max-w-7xl mx-auto px-4 md:px-6 py-14 md:py-20 text-center">
      <div data-reveal class="font-mono text-[10px] tracking-widest uppercase text-gold/60 mb-3">Ready to Order?</div>
      <h2 data-reveal data-split-words data-split-scroll="1" class="font-display text-2xl md:text-3xl font-bold text-chrome-50 mb-4">Get in touch with us today</h2>
      <p data-reveal class="text-chrome-200/60 text-sm md:text-base mb-8 max-w-lg mx-auto">We offer 24/7 service and fast delivery across Sri Lanka. Contact us via WhatsApp, phone or email.</p>
      <div data-reveal class="flex flex-wrap gap-3 justify-center">
        <a href="/contact" data-magnetic class="btn-shine inline-flex items-center gap-2 px-6 py-3.5 rounded-md bg-gold text-ink-900 font-medium text-sm hover:shadow-glow-cyan transition-all">
          Contact Us
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12,5 19,12 12,19"/></svg>
        </a>
        <a href="/categories" data-magnetic class="btn-shine inline-flex items-center gap-2 px-6 py-3.5 rounded-md border hairline-strong text-chrome-50 hover:border-gold/60 hover:text-gold font-medium text-sm bg-ink-600/40 transition-all">
          Browse Products
        </a>
      </div>
    </div>
  </section>

</Layout>
