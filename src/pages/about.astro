---
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import BearingSVG from "../components/BearingSVG.astro";
import { BUSINESS, BRANDS, CATEGORIES } from "../data/rcb";

const values = [
  {
    title: "Quality Assurance",
    desc:  "Every product we stock is sourced from verified, ISO-certified manufacturers. No counterfeits, no compromises.",
    icon:  `<path d="M9 12l2 2 4-4m5.5 3.5A9.5 9.5 0 1 1 3 9.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    title: "Reliability",
    desc:  "24/7 service means your production line doesn't wait for business hours. We pick up the phone when it matters.",
    icon:  `<path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48 2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48 2.83-2.83" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
  {
    title: "Customer Satisfaction",
    desc:  "We match specifications first — if we don't have it in stock we'll source it, and we'll tell you the honest lead time.",
    icon:  `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
  {
    title: "Business Integrity",
    desc:  "Transparent pricing, accurate specifications and no up-selling of unnecessary components — your long-term success is ours.",
    icon:  `<rect x="3" y="11" width="18" height="11" rx="2" ry="2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M7 11V7a5 5 0 0 1 10 0v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
  {
    title: "Continuous Improvement",
    desc:  "We expand our range, improve our logistics, and deepen our technical knowledge so every visit leaves you better informed.",
    icon:  `<polyline points="23 6 13.5 15.5 8.5 10.5 1 18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><polyline points="17 6 23 6 23 12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
];

const stats = [
  { n: "18",  label: "Product Categories" },
  { n: "12+", label: "Premium Brands"     },
  { n: "24/7", label: "Service Hours"     },
  { n: "LK",  label: "Island-wide Supply" },
];

const timeline = [
  { year: "Founded",    text: "Royal Crown Bearings was established with a single goal: bring world-class bearing brands to Sri Lanka at competitive prices, backed by real technical expertise." },
  { year: "Growth",     text: "Expanded to cover all major bearing families — ball, roller, thrust, mounted units — plus V-belts and oil seals, becoming a one-stop shop for industrial drive components." },
  { year: "Today",      text: "Operating 24/7 with an island-wide supply network, stocking NTN, NSK, FAG, SKF, TIMKEN and more — serving vehicle workshops, machinery maintenance teams and manufacturing plants." },
  { year: "Vision",     text: "Become the most trusted precision bearing supplier in Sri Lanka by combining quality products, technical consultation and rapid fulfilment." },
];
---

<Layout
  title="About Royal Crown Bearings — Premium Industrial Supplier, Sri Lanka"
  description="Learn about Royal Crown Bearings — Sri Lanka's trusted supplier of NTN, NSK, FAG, SKF, TIMKEN bearings, V-belts, oil seals and industrial components. Quality, reliability and 24/7 service."
>
  <NavBar slot="navbar" currentPath="/about" />

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <section class="relative pt-28 pb-20 tech-grid overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 60% 50% at 30% -10%,rgba(0,224,255,0.08),transparent 70%)"></div>

    <!-- Decorative bearings -->
    <div class="absolute right-0 top-12 opacity-10 pointer-events-none hidden xl:block">
      <BearingSVG type="groove" size={380} id="about-bg-1" spinClass="spin-slower" />
    </div>
    <div class="absolute right-24 top-32 opacity-5 pointer-events-none hidden xl:block">
      <BearingSVG type="cylindrical" size={200} id="about-bg-2" spinClass="spin-rev" />
    </div>

    <div class="max-w-7xl mx-auto px-5 sm:px-6 relative z-10">
      <nav class="flex items-center gap-2 font-mono text-[11px] tracking-[0.2em] uppercase text-chrome-200/50 mb-10 gsap-reveal" aria-label="Breadcrumb">
        <a href="/" class="hover:text-cyan-brand transition-colors">Home</a>
        <span class="text-chrome-200/30">/</span>
        <span class="text-chrome-200/80">About Us</span>
      </nav>

      <div class="max-w-3xl">
        <div class="flex items-center gap-3 font-mono text-[11px] tracking-[0.28em] uppercase mb-5 gsap-reveal">
          <span class="inline-block w-6 h-px bg-cyan-brand"></span>
          <span class="text-cyan-brand">Who We Are</span>
        </div>
        <h1 class="font-display text-4xl sm:text-6xl font-bold tracking-tight text-chrome-50 leading-[1.05] gsap-reveal">
          Powering Sri Lanka's<br class="hidden sm:block"/> Industrial Backbone
        </h1>
        <p class="mt-6 text-lg text-chrome-100/70 leading-relaxed gsap-reveal max-w-2xl">
          {BUSINESS.mission}
        </p>

        <div class="mt-8 flex flex-wrap gap-4 gsap-reveal">
          <button onclick="openEnquiryModal([])"
                  class="inline-flex items-center gap-2 font-medium tracking-tight rounded-md transition-all px-5 py-2.5 text-sm bg-amber-signal text-ink-900 hover:bg-white hover:shadow-glow-amber btn-shine">
            Send Enquiry
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="13,6 19,12 13,18"/>
            </svg>
          </button>
          <a href="/categories"
             class="inline-flex items-center gap-2 font-medium tracking-tight rounded-md transition-all px-5 py-2.5 text-sm border hairline-strong text-chrome-50 hover:border-cyan-brand/50 hover:text-cyan-brand bg-ink-800/40 btn-shine">
            Browse Products
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Stats ─────────────────────────────────────────────────────────── -->
  <section class="border-y hairline bg-ink-800/30">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 py-10 grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-0 md:divide-x divide-white/5">
      {stats.map((s) => (
        <div class="stat-card flex flex-col items-center justify-center py-4">
          <div class="font-display text-4xl font-bold text-chrome-50 mb-1">{s.n}</div>
          <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-chrome-200/55">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Mission / Vision ───────────────────────────────────────────────── -->
  <section class="max-w-7xl mx-auto px-5 sm:px-6 py-20 grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="mv-card chrome-border rounded-2xl bg-ink-800/50 p-8 flex flex-col gap-4">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg border hairline-strong bg-cyan-brand/10 grid place-items-center shrink-0">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#00E0FF" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
          </svg>
        </div>
        <div class="font-mono text-[10px] tracking-[0.28em] uppercase text-cyan-brand">Our Mission</div>
      </div>
      <p class="text-chrome-50 text-lg leading-relaxed">{BUSINESS.mission}</p>
    </div>
    <div class="mv-card chrome-border rounded-2xl bg-ink-800/50 p-8 flex flex-col gap-4">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg border hairline-strong bg-amber-signal/10 grid place-items-center shrink-0">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#FFB347" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M1 6l11 7L23 6"/><path d="M1 6v12a2 2 0 0 0 2 2h18a2 2 0 0 0 2-2V6"/>
          </svg>
        </div>
        <div class="font-mono text-[10px] tracking-[0.28em] uppercase text-amber-signal">Our Vision</div>
      </div>
      <p class="text-chrome-50 text-lg leading-relaxed">{BUSINESS.vision}</p>
    </div>
  </section>

  <!-- ── Core values ────────────────────────────────────────────────────── -->
  <section class="border-t hairline bg-ink-800/20 py-20">
    <div class="max-w-7xl mx-auto px-5 sm:px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center gap-3 font-mono text-[11px] tracking-[0.28em] uppercase mb-4 value-reveal">
          <span class="inline-block w-6 h-px bg-cyan-brand"></span>
          <span class="text-cyan-brand">What Drives Us</span>
          <span class="inline-block w-6 h-px bg-cyan-brand"></span>
        </div>
        <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tight text-chrome-50 value-reveal">Core Values</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {values.map((v, i) => (
          <div class="value-card chrome-border rounded-xl bg-ink-800/60 p-6 flex flex-col gap-4 hover:bg-ink-800/80 transition-all duration-300 hover:-translate-y-0.5">
            <div class="w-10 h-10 rounded-lg border hairline-strong bg-ink-700/60 grid place-items-center shrink-0">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none">{v.icon && <Fragment set:html={v.icon} />}</svg>
            </div>
            <div>
              <h3 class="font-display text-base font-semibold text-chrome-50 mb-2">{v.title}</h3>
              <p class="text-sm text-chrome-100/70 leading-relaxed">{v.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Story timeline ─────────────────────────────────────────────────── -->
  <section class="max-w-5xl mx-auto px-5 sm:px-6 py-20">
    <div class="text-center mb-14">
      <div class="flex items-center justify-center gap-3 font-mono text-[11px] tracking-[0.28em] uppercase mb-4 story-reveal">
        <span class="inline-block w-6 h-px bg-cyan-brand"></span>
        <span class="text-cyan-brand">Our Journey</span>
        <span class="inline-block w-6 h-px bg-cyan-brand"></span>
      </div>
      <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tight text-chrome-50 story-reveal">The RCB Story</h2>
    </div>

    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-6 sm:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-cyan-brand/30 via-cyan-brand/10 to-transparent pointer-events-none -translate-x-1/2"></div>

      <div class="flex flex-col gap-12">
        {timeline.map((item, i) => (
          <div class={`timeline-item relative flex gap-6 sm:gap-10 ${i % 2 === 0 ? 'sm:flex-row' : 'sm:flex-row-reverse sm:text-right'}`}>
            <!-- Dot -->
            <div class="absolute left-6 sm:left-1/2 w-3 h-3 rounded-full bg-cyan-brand border-2 border-ink-900 -translate-x-1/2 mt-1.5 shrink-0 z-10"></div>

            <!-- Spacer for alternating layout -->
            <div class="hidden sm:block flex-1"></div>

            <!-- Card -->
            <div class="flex-1 pl-14 sm:pl-0 sm:max-w-[calc(50%-2rem)]">
              <div class="chrome-border rounded-xl bg-ink-800/60 p-5">
                <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-cyan-brand mb-2">{item.year}</div>
                <p class="text-sm text-chrome-100/80 leading-relaxed">{item.text}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Brand partners ─────────────────────────────────────────────────── -->
  <section class="border-t hairline bg-ink-800/20 py-16">
    <div class="max-w-7xl mx-auto px-5 sm:px-6">
      <div class="text-center mb-10 brand-reveal">
        <div class="font-mono text-[10px] tracking-[0.28em] uppercase text-chrome-200/50 mb-2">Authorised Distributor</div>
        <h2 class="font-display text-2xl font-semibold text-chrome-50">Our Brand Portfolio</h2>
      </div>
      <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-3">
        {BRANDS.map((b) => (
          <div class="brand-tile chrome-border rounded-xl bg-ink-800/60 px-4 py-5 flex flex-col items-center gap-2 hover:bg-ink-800/80 transition-all duration-300 hover:-translate-y-0.5">
            <div class="font-display text-base font-bold text-chrome-50">{b.name}</div>
            <div class="font-mono text-[8px] tracking-[0.22em] uppercase text-chrome-200/40">{b.country}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────────────────────── -->
  <section class="py-20">
    <div class="max-w-3xl mx-auto px-5 sm:px-6 text-center cta-reveal">
      <div class="font-mono text-[11px] tracking-[0.28em] uppercase text-amber-signal mb-3">Get in touch</div>
      <h2 class="font-display text-2xl sm:text-3xl font-bold text-chrome-50 mb-4">Ready to source your components?</h2>
      <p class="text-chrome-100/70 mb-8">Talk to our team — we'll match the right bearing, belt or seal to your specification.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/contact"
           class="inline-flex items-center gap-2 font-medium tracking-tight rounded-md transition-all px-6 py-3 text-[15px] bg-amber-signal text-ink-900 hover:bg-white hover:shadow-glow-amber btn-shine">
          Contact Us
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="13,6 19,12 13,18"/>
          </svg>
        </a>
        <a href="/categories"
           class="inline-flex items-center gap-2 font-medium tracking-tight rounded-md transition-all px-6 py-3 text-[15px] border hairline-strong text-chrome-50 hover:border-cyan-brand/50 hover:text-cyan-brand bg-ink-800/40 btn-shine">
          Browse All Categories
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Hero entrance
  gsap.fromTo('.gsap-reveal',
    { opacity: 0, y: 20 },
    { opacity: 1, y: 0, duration: 0.6, stagger: 0.1, ease: 'power2.out', delay: 0.1 }
  );

  // Stats counter
  ScrollTrigger.create({
    trigger: '.stat-card',
    start: 'top 88%',
    once: true,
    onEnter: () => gsap.fromTo('.stat-card',
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.5, stagger: 0.1, ease: 'power2.out' }
    ),
  });

  // Mission / Vision
  ScrollTrigger.batch('.mv-card', {
    onEnter: (els) => gsap.fromTo(els,
      { opacity: 0, x: (el, i) => (i === 0 ? -25 : 25) },
      { opacity: 1, x: 0, duration: 0.65, stagger: 0.1, ease: 'power2.out' }
    ),
    start: 'top 88%',
    once: true,
  });

  // Values
  ScrollTrigger.batch('.value-reveal, .value-card', {
    onEnter: (els) => gsap.fromTo(els,
      { opacity: 0, y: 22 },
      { opacity: 1, y: 0, duration: 0.5, stagger: 0.08, ease: 'power2.out' }
    ),
    start: 'top 90%',
    once: true,
  });

  // Timeline
  ScrollTrigger.batch('.timeline-item', {
    onEnter: (els) => gsap.fromTo(els,
      { opacity: 0, y: 24 },
      { opacity: 1, y: 0, duration: 0.55, stagger: 0.12, ease: 'power2.out' }
    ),
    start: 'top 90%',
    once: true,
  });

  // Brand tiles
  ScrollTrigger.batch('.brand-tile, .brand-reveal', {
    onEnter: (els) => gsap.fromTo(els,
      { opacity: 0, scale: 0.9 },
      { opacity: 1, scale: 1, duration: 0.4, stagger: 0.04, ease: 'back.out(1.4)' }
    ),
    start: 'top 92%',
    once: true,
  });

  // CTA
  ScrollTrigger.create({
    trigger: '.cta-reveal',
    start: 'top 88%',
    once: true,
    onEnter: () => gsap.fromTo('.cta-reveal', { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' }),
  });
</script>
