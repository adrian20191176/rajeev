---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Page Not Found | Royal Crown Bearings"
  description="Page not found."
  activeNav=""
  canonicalPath="/404"
  noindex
>
  <section class="relative min-h-[calc(100vh-220px)] border-b hairline overflow-hidden">
    <div class="absolute inset-0 tech-grid pointer-events-none opacity-50"></div>
    <div class="absolute inset-0 spot pointer-events-none"></div>

    <div class="relative max-w-3xl mx-auto px-5 sm:px-6 py-20 sm:py-28 text-center">
      <div class="font-mono text-[12px] tracking-widest uppercase text-gold mb-4">
        404
      </div>
      <h1 class="font-display text-4xl sm:text-5xl font-semibold tracking-tight text-chrome-50">
        Page not found
      </h1>
      <p class="mt-4 text-base text-chrome-100/75 leading-relaxed">
        The page you are looking for does not exist.
      </p>
      <div class="mt-8">
        <a
          href="/"
          class="btn-shine inline-flex items-center justify-center gap-2 px-5 py-3.5 rounded-md bg-amber-signal text-ink-900 font-medium text-sm hover:bg-gold hover:shadow-glow-amber"
        >
          Go to home page
        </a>
      </div>
    </div>
  </section>
</Layout>