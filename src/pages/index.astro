---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteScripts from "../components/SiteScripts.astro";
import {
	advantages,
	brands,
	categories,
	contact,
	deepGrooveProducts,
	searchableItems,
	values,
} from "../data/catalog";
import "../styles/global.css";

const featuredCategories = categories.slice(0, 8);
const featuredProducts = deepGrooveProducts.slice(0, 12);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Royal Crown Bearings supplies bearings, V-belts, oil seals, housings, and industrial components in Sri Lanka."
		/>
		<title>Royal Crown Bearings</title>
	</head>
	<body>
		<SiteHeader current="Home" />

		<main id="top">
			<section class="hero hero-wide section-shell">
				<div class="hero-copy" data-reveal>
					<p class="eyebrow">Bearing, belt and industrial component supplier</p>
					<h1>Royal Crown Bearings</h1>
					<p class="hero-lede">
						Powering performance and ensuring reliability with durable components, practical stock
						support, and product guidance for industrial and automotive customers.
					</p>

					<div class="hero-actions">
						<a class="button button-primary" href="/categories/">Explore categories</a>
						<a class="button button-secondary" href={contact.whatsapp}>Ask on WhatsApp</a>
					</div>

					<div class="signal-grid" aria-label="Business highlights">
						<div>
							<strong>{categories.length}</strong>
							<span>Categories</span>
						</div>
						<div>
							<strong>{deepGrooveProducts.length}</strong>
							<span>Listed products</span>
						</div>
						<div>
							<strong>24/7</strong>
							<span>Service availability</span>
						</div>
					</div>
				</div>

				<div class="hero-command" data-reveal>
					<div class="logo-stage logo-stage-compact">
						<img src="/images/logo.svg" alt="Royal Crown Bearings RCB logo" width="1034" height="1109" />
					</div>

					<div class="search-console" data-filter-scope data-hide-until-search>
						<div>
							<p class="eyebrow">Catalog search</p>
							<h2>Find a category or bearing code.</h2>
						</div>
						<label class="search-field">
							<span>Search catalog</span>
							<input
								type="search"
								placeholder="Try 6205-2RS, oil seals, V-belts, SKF..."
								autocomplete="off"
								data-filter-input
							/>
						</label>
						<div class="catalog-meta">
							<span data-filter-count>Start typing to search</span>
							<span>Categories and Deep Groove products</span>
						</div>
						<div class="search-results">
							{searchableItems.map((item) => (
								<a class="search-result" href={item.url} data-filter-item data-search={item.searchText}>
									<span>{item.type}</span>
									<strong>{item.title}</strong>
									<small>{item.description}</small>
								</a>
							))}
						</div>
						<p class="empty-state" hidden data-filter-empty>No matching category or product found.</p>
					</div>
				</div>
			</section>

			<section class="section-shell intro-band" data-reveal>
				<div class="section-heading">
					<p class="eyebrow">Built for reliability</p>
					<h2>Category-first browsing for fast product matching.</h2>
				</div>
				<p>
					Browse by category first, then open the category page to view available products. The
					Deep Groove Ball Bearings category is populated now; other categories are ready for images
					and product entries as stock data becomes available.
				</p>
			</section>

			<section class="section-shell section-block" id="categories">
				<div class="section-heading" data-reveal>
					<p class="eyebrow">Categories</p>
					<h2>Start with the component family.</h2>
					<p>
						Open a category to view available products, request stock details, or continue browsing
						related component families.
					</p>
				</div>

				<div class="category-rail" aria-label="Featured categories">
					{featuredCategories.map((category) => (
						<a
							class="category-showcase-card"
							href={`/categories/${category.slug}/`}
							data-reveal
							data-search={`${category.name} ${category.summary} ${category.tags.join(" ")}`.toLowerCase()}
						>
							<div class="image-placeholder" aria-hidden="true">
								<span>{category.imageLabel}</span>
							</div>
							<div>
								<span class="status-pill">{category.status}</span>
								<h3>{category.name}</h3>
								<p>{category.summary}</p>
							</div>
						</a>
					))}
				</div>

				<div class="section-actions">
					<a class="button button-primary" href="/categories/">View all categories</a>
				</div>
			</section>

			<section class="section-shell section-block">
				<div class="feature-panel" data-reveal>
					<div class="section-heading compact">
						<p class="eyebrow">Active product category</p>
						<h2>Deep Groove Ball Bearings</h2>
						<p>
							These bearing codes are products inside the Deep Groove Ball Bearings category.
						</p>
					</div>

					<div class="product-preview-grid">
						{featuredProducts.map((product) => (
							<a class="product-card compact-product" href={`/categories/${product.categorySlug}/?q=${encodeURIComponent(product.sku)}`}>
								<div class="product-image-placeholder" aria-hidden="true">
									<span>{product.imageLabel}</span>
								</div>
								<div>
									<strong>{product.sku}</strong>
									<span>{product.series}</span>
									<small>{product.variant}</small>
								</div>
							</a>
						))}
					</div>

					<div class="section-actions">
						<a class="button button-secondary" href="/categories/deep-groove-ball-bearings/">
							View all Deep Groove products
						</a>
					</div>
				</div>
			</section>

			<section class="section-shell section-block">
				<div class="section-heading" data-reveal>
					<p class="eyebrow">Popular brands</p>
					<h2>Recognized names customers ask for.</h2>
				</div>

				<div class="brand-grid" aria-label="Popular brands">
					{brands.map((brand) => (
						<div class="brand-tile" data-reveal>{brand}</div>
					))}
				</div>
			</section>

			<section class="section-shell about-section section-block" id="about">
				<div class="about-copy" data-reveal>
					<p class="eyebrow">About Royal Crown Bearings</p>
					<h2>Cost-effective components backed by technical product knowledge.</h2>
					<p>
						Royal Crown Bearings supplies high-quality bearings, belts, oil seals, housings, and
						industrial components selected for long service life and dependable performance.
					</p>
					<p>
						The goal is to become a trusted bearing supplier in Sri Lanka by combining quality
						products, practical expertise, and responsive customer service.
					</p>
				</div>

				<div class="values-layout">
					<div class="info-panel" data-reveal>
						<h3>Core values</h3>
						<ul>
							{values.map((value) => <li>{value}</li>)}
						</ul>
					</div>
					<div class="info-panel accent-panel" data-reveal>
						<h3>Why customers choose RCB</h3>
						<ul>
							{advantages.map((advantage) => <li>{advantage}</li>)}
						</ul>
					</div>
				</div>
			</section>

			<section class="section-shell contact-section" id="contact">
				<div class="contact-card" data-reveal>
					<div>
						<p class="eyebrow">Contact</p>
						<h2>Find the right component faster.</h2>
						<p>
							Share a bearing code, category, brand preference, or equipment requirement and the
							team will help match the correct product.
						</p>
					</div>

					<div class="contact-actions">
						<a class="button button-primary" href={contact.whatsapp}>Message on WhatsApp</a>
						<a class="button button-secondary" href={contact.emailHref}>{contact.email}</a>
					</div>

					<dl class="contact-details">
						<div>
							<dt>Phone</dt>
							<dd><a href={contact.phoneHref}>{contact.phone}</a></dd>
						</div>
						<div>
							<dt>Website</dt>
							<dd>{contact.website}</dd>
						</div>
						<div>
							<dt>Business hours</dt>
							<dd>{contact.hours}</dd>
						</div>
					</dl>
				</div>
			</section>
		</main>

		<SiteFooter />
		<SiteScripts />
	</body>
</html>
