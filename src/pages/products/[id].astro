---
import Layout from "../../layouts/Layout.astro";
import NavBar from "../../components/NavBar.astro";
import Footer from "../../components/Footer.astro";
import BearingSVG from "../../components/BearingSVG.astro";
import { CATEGORIES, PRODUCTS } from "../../data/rcb";

export function getStaticPaths() {
  return PRODUCTS.map((p) => ({ params: { id: String(p.id) } }));
}

const id      = Number(Astro.params.id);
const product = PRODUCTS.find((p) => p.id === id)!;
const cat     = CATEGORIES.find((c) => c.slug === product.category)!;

// Related products — same category, different id, max 4
const related = PRODUCTS.filter((p) => p.category === product.category && p.id !== id).slice(0, 4);

// Build spec rows
type SpecRow = { label: string; value: string | number };
const specs: SpecRow[] = [];
if (product.bore)    specs.push({ label: 'Bore Diameter',   value: `${product.bore} mm` });
if (product.od)      specs.push({ label: 'Outer Diameter',  value: `${product.od} mm` });
if (product.width)   specs.push({ label: 'Width',           value: `${product.width} mm` });
if (product.section) specs.push({ label: 'Belt Section',    value: product.section });
if (product.pitch)   specs.push({ label: 'Pitch',           value: product.pitch });
if (product.length)  specs.push({ label: 'Length',          value: `${product.length} mm` });
if (product.series)  specs.push({ label: 'Housing Series',  value: product.series });
specs.push({ label: 'Brand',        value: product.brand });
specs.push({ label: 'Part Code',    value: product.code });
specs.push({ label: 'Availability', value: product.availability });

const canonicalUrl = `https://royalcrownbearings.com/products/${id}`;
const waMsg = encodeURIComponent(`Hi, I'd like to enquire about: ${product.name} (${product.code}) — Brand: ${product.brand}`);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.name,
  "description": `${product.name} by ${product.brand}. Part code: ${product.code}. ${cat.short}`,
  "sku": product.code,
  "brand": { "@type": "Brand", "name": product.brand },
  "category": cat.name,
  "offers": {
    "@type": "Offer",
    "availability": product.availability === 'In Stock'
      ? "https://schema.org/InStock"
      : "https://schema.org/PreOrder",
    "priceCurrency": "LKR",
    "seller": { "@type": "Organization", "name": "Royal Crown Bearings" },
  },
  "url": canonicalUrl,
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home",       "item": "https://royalcrownbearings.com" },
      { "@type": "ListItem", "position": 2, "name": "Categories", "item": "https://royalcrownbearings.com/categories" },
      { "@type": "ListItem", "position": 3, "name": cat.name,     "item": `https://royalcrownbearings.com/categories/${cat.slug}` },
      { "@type": "ListItem", "position": 4, "name": product.name, "item": canonicalUrl },
    ],
  },
};
---

<Layout
  title={`${product.name} ${product.code} — ${product.brand}`}
  description={`Buy ${product.name} (${product.code}) by ${product.brand} at Royal Crown Bearings Sri Lanka. ${cat.short} Available in stock.`}
  canonical={canonicalUrl}
  jsonLd={jsonLd}
>
  <NavBar slot="navbar" currentPath="/categories" />

  <div class="max-w-7xl mx-auto px-5 sm:px-6 pt-28 pb-20">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 font-mono text-[11px] tracking-[0.2em] uppercase text-chrome-200/50 mb-10 flex-wrap gsap-reveal" aria-label="Breadcrumb">
      <a href="/" class="hover:text-cyan-brand transition-colors">Home</a>
      <span class="text-chrome-200/30">/</span>
      <a href="/categories" class="hover:text-cyan-brand transition-colors">Categories</a>
      <span class="text-chrome-200/30">/</span>
      <a href={`/categories/${cat.slug}`} class="hover:text-cyan-brand transition-colors truncate max-w-[120px] sm:max-w-none">{cat.name}</a>
      <span class="text-chrome-200/30">/</span>
      <span class="text-chrome-200/80">{product.code}</span>
    </nav>

    <!-- Main product layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <!-- ── Visual panel ──── -->
      <div class="gsap-panel-left">
        <div class="chrome-border rounded-2xl bg-ink-800/60 p-8 flex flex-col items-center justify-center min-h-[300px] relative overflow-hidden">
          <div class="absolute inset-0 tech-grid opacity-40 pointer-events-none"></div>
          <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(circle at 50% 40%,rgba(0,224,255,0.06),transparent 65%)"></div>

          <div class="relative z-10 w-48 h-48 sm:w-56 sm:h-56">
            <BearingSVG
              type={product.iconType as any}
              size={220}
              id={`product-${id}`}
              spinClass="spin-slow"
              class="w-full h-full"
            />
          </div>

          <!-- HUD labels -->
          <div class="relative z-10 mt-6 grid grid-cols-2 gap-4 w-full max-w-xs">
            <div class="text-center">
              <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-chrome-200/40">Part Code</div>
              <div class="font-mono text-sm text-cyan-brand mt-1 font-semibold">{product.code}</div>
            </div>
            <div class="text-center">
              <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-chrome-200/40">Brand</div>
              <div class="font-mono text-sm text-chrome-50 mt-1 font-semibold">{product.brand}</div>
            </div>
          </div>
        </div>

        <!-- Availability badge -->
        <div class="mt-4 flex items-center justify-center">
          <span class={`inline-flex items-center gap-2 font-mono text-[11px] tracking-[0.18em] uppercase px-3 py-1.5 rounded-full border ${product.availability === 'In Stock' ? 'text-emerald-400 border-emerald-400/30 bg-emerald-400/5' : 'text-amber-signal border-amber-signal/30 bg-amber-signal/5'}`}>
            {product.availability === 'In Stock' ? (
              <><span class="w-1.5 h-1.5 rounded-full bg-emerald-400 live-dot"></span>In Stock</>
            ) : (
              <><span class="w-1.5 h-1.5 rounded-full bg-amber-signal"></span>Available on Pre-order</>
            )}
          </span>
        </div>
      </div>

      <!-- ── Info panel ──── -->
      <div class="gsap-panel-right">
        <div class="flex items-center gap-3 font-mono text-[11px] tracking-[0.28em] uppercase mb-3">
          <span class="inline-block w-6 h-px bg-cyan-brand"></span>
          <a href={`/categories/${cat.slug}`} class="text-cyan-brand hover:text-cyan-brand/70 transition-colors">{cat.family}</a>
        </div>

        <h1 class="font-display text-3xl sm:text-4xl font-bold tracking-tight text-chrome-50 leading-[1.1] mb-2">
          {product.name}
        </h1>
        <p class="font-mono text-[12px] tracking-[0.18em] text-chrome-200/60 mb-6">{product.brand} · {product.code}</p>

        <p class="text-chrome-100/75 leading-relaxed mb-8">{cat.description}</p>

        <!-- Specs table -->
        <div class="chrome-border rounded-xl overflow-hidden mb-8">
          <div class="px-4 py-2.5 border-b hairline bg-ink-700/40">
            <span class="font-mono text-[10px] tracking-[0.28em] uppercase text-chrome-200/60">Specifications</span>
          </div>
          <div class="divide-y divide-white/5">
            {specs.map((s) => (
              <div class="flex items-center justify-between px-4 py-2.5">
                <span class="font-mono text-[11px] tracking-[0.14em] uppercase text-chrome-200/50">{s.label}</span>
                <span class={`font-mono text-[12px] font-semibold ${s.label === 'Availability' ? (product.availability === 'In Stock' ? 'text-emerald-400' : 'text-amber-signal') : 'text-chrome-50'}`}>
                  {s.value}
                </span>
              </div>
            ))}
          </div>
        </div>

        <!-- Actions -->
        <div class="flex flex-col gap-3">
          <button
            id="add-enquiry-btn"
            onclick={`addToEnquiry(${id}); document.getElementById('add-enquiry-btn').classList.add('added');`}
            class="inline-flex items-center justify-center gap-2 font-medium tracking-tight rounded-md transition-all duration-200 px-5 py-3.5 text-[15px] bg-amber-signal text-ink-900 hover:bg-white hover:shadow-glow-amber btn-shine"
          >
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Add to Enquiry List
          </button>

          <div class="grid grid-cols-2 gap-2">
            <a href={`https://wa.me/94766550249?text=${waMsg}`} target="_blank" rel="noopener"
               class="inline-flex items-center justify-center gap-2 font-medium tracking-tight rounded-md transition-all duration-200 px-4 py-3 text-sm border hairline-strong bg-ink-800/40 text-chrome-50 hover:border-amber-signal/50 hover:text-amber-signal btn-shine">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
                <path d="M20.5 3.5A11 11 0 0 0 3.7 17.3L2 22l4.8-1.6A11 11 0 1 0 20.5 3.5z"/>
              </svg>
              WhatsApp
            </a>
            <a href="tel:+94766550249"
               class="inline-flex items-center justify-center gap-2 font-medium tracking-tight rounded-md transition-all duration-200 px-4 py-3 text-sm border hairline-strong bg-ink-800/40 text-chrome-50 hover:border-cyan-brand/40 hover:text-cyan-brand btn-shine">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 4h4l2 5-3 2a12 12 0 0 0 5 5l2-3 5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"/>
              </svg>
              Call Us
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Related products ───────────────────────────────────────────── -->
    {related.length > 0 && (
      <section class="mt-20">
        <div class="flex items-center gap-4 mb-8">
          <div>
            <div class="font-mono text-[10px] tracking-[0.28em] uppercase text-chrome-200/50 mb-1">More from this category</div>
            <h2 class="font-display text-xl font-semibold text-chrome-50">Related Products</h2>
          </div>
          <div class="flex-1 h-px bg-gradient-to-r from-white/10 to-transparent"></div>
          <a href={`/categories/${cat.slug}`}
             class="font-mono text-[10px] tracking-[0.18em] uppercase text-cyan-brand hover:text-cyan-brand/70 transition-colors shrink-0">
            View All →
          </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {related.map((r) => (
            <a href={`/products/${r.id}`}
               class="related-card group chrome-border rounded-xl bg-ink-800/60 p-4 flex flex-col gap-3 hover:bg-ink-800/80 transition-all duration-300 hover:-translate-y-0.5">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 shrink-0 rounded-lg border hairline-strong bg-ink-700/60 grid place-items-center overflow-hidden">
                  <BearingSVG type={r.iconType as any} size={36} />
                </div>
                <div>
                  <div class="font-mono text-[11px] tracking-[0.16em] text-cyan-brand/80">{r.code}</div>
                  <div class="font-mono text-[9px] uppercase tracking-[0.2em] text-chrome-200/50">{r.brand}</div>
                </div>
              </div>
              <div class="font-display text-sm text-chrome-50 group-hover:text-cyan-brand transition-colors leading-snug line-clamp-2">{r.name}</div>
              {r.diameter && (
                <div class="font-mono text-[10px] text-chrome-200/50">{r.diameter}</div>
              )}
            </a>
          ))}
        </div>
      </section>
    )}
  </div>

  <Footer slot="footer" />
</Layout>

<style>
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  #add-enquiry-btn.added {
    background: rgba(0,224,255,0.15);
    color: #00E0FF;
    border: 1px solid rgba(0,224,255,0.30);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo('.gsap-reveal', { opacity: 0, y: 14 }, { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' });

  const tl = gsap.timeline({ defaults: { ease: 'power2.out' } });
  tl.fromTo('.gsap-panel-left',  { opacity: 0, x: -30 }, { opacity: 1, x: 0, duration: 0.7 }, 0.1)
    .fromTo('.gsap-panel-right', { opacity: 0, x:  30 }, { opacity: 1, x: 0, duration: 0.7 }, 0.2);

  ScrollTrigger.batch('.related-card', {
    onEnter: (els) => gsap.fromTo(els,
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.4, stagger: 0.07, ease: 'power2.out' }
    ),
    start: 'top 92%',
    once: true,
  });
</script>
