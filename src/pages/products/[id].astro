---
import Layout from '../../layouts/Layout.astro';
import BearingVisual from '../../components/BearingVisual.astro';
import { getCategories, getProducts } from '../../data/rcb.js';

export async function getStaticPaths() {
  const [allProducts, CATEGORIES] = await Promise.all([getProducts(), getCategories()]);
  return allProducts.map((product) => {
    const cat = CATEGORIES.find((c) => c.slug === product.category);
    const related = allProducts
      .filter((p) => p.category === product.category && p.id !== product.id)
      .slice(0, 4);
    return {
      params: { id: String(product.id) },
      props: { product, cat, related },
    };
  });
}

const { product, cat, related } = Astro.props;

const specs = [
  product.bore  !== undefined && { label: 'Bore (d)',     value: `${product.bore} mm` },
  product.od    !== undefined && { label: 'OD (D)',        value: `${product.od} mm` },
  product.width !== undefined && { label: 'Width (B)',     value: `${product.width} mm` },
  product.length !== undefined && { label: 'Length',       value: `${product.length} mm` },
  product.section !== undefined && { label: 'Section',     value: product.section },
  product.pitch !== undefined && { label: 'Pitch',         value: product.pitch },
  product.series !== undefined && { label: 'Series',       value: product.series },
  { label: 'Category',          value: cat?.name ?? product.category },
].filter(Boolean);

const waRawMsg = `Hi, I'd like to enquire about: ${product.name} (ID: ${product.id}). Please send availability and pricing.`;
const waMsg = encodeURIComponent(waRawMsg);

const availabilityBadge = product.availability === 'Pre-order'
  ? { label: 'Pre-order', dot: 'bg-amber-signal', cls: 'bg-amber-signal/15 text-amber-signal' }
  : product.availability === 'Out of Stock'
  ? { label: 'Out of Stock', dot: 'bg-chrome-200/60', cls: 'bg-chrome-200/10 text-chrome-200/70' }
  : { label: 'In Stock', dot: 'bg-emerald-400', cls: 'bg-emerald-500/10 text-emerald-400' };
---

<Layout
  title={`${product.code} | Royal Crown Bearings`}
  description={`${product.name}. ${product.diameter || ''} — ${cat?.short || ''}`}
  activeNav="categories"
  waMessage={waRawMsg}
>

  <!-- Breadcrumb + header -->
  <section class="relative border-b hairline overflow-hidden">
    <div class="absolute inset-0 tech-grid pointer-events-none"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 md:px-6 pt-10 pb-12 md:pt-14 md:pb-14">
      <div class="font-mono text-[12px] tracking-widest uppercase text-gold/70 mb-4 flex items-center gap-2 flex-wrap">
        <a href="/" class="hover:text-gold transition-colors">Home</a>
        <span class="text-chrome-200/50">/</span>
        <a href="/categories" class="hover:text-gold transition-colors">Categories</a>
        <span class="text-chrome-200/50">/</span>
        <a href={`/categories/${product.category}`} class="hover:text-gold transition-colors">{cat?.name}</a>
        <span class="text-chrome-200/50">/</span>
        <span class="text-chrome-200/70">{product.code}</span>
      </div>

      <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 items-start">
        <!-- Visual -->
        <div data-hero-step class="shrink-0 w-full max-w-[240px] mx-auto lg:mx-0">
          <div data-tilt data-tilt-max="8" class="aspect-square rounded-xl border hairline bg-ink-700/30 flex items-center justify-center" style="box-shadow: var(--shadow-card)">
            {product.image
              ? <img src={product.image} alt={product.name} class="w-full h-full object-contain p-8" />
              : <div class="w-40 h-40 opacity-90 spin-slower">
                  <BearingVisual iconType={cat?.iconType ?? 'groove'} size={160} />
                </div>
            }
          </div>
        </div>

        <!-- Info -->
        <div class="flex-1">
          <div data-hero-step class="font-mono text-[12px] tracking-widest uppercase text-gold/60 mb-2">{cat?.family}</div>
          <h1 data-hero-step data-split-words class="font-display text-2xl md:text-3xl lg:text-4xl font-bold text-chrome-50 tracking-tight">{product.code}</h1>
          {product.diameter && <p data-hero-step class="mt-1 font-mono text-sm text-chrome-200/75">{product.diameter}</p>}

          <div class={`mt-3 inline-flex items-center gap-1.5 font-mono text-[12px] tracking-widest uppercase px-3 py-1.5 rounded-full ${availabilityBadge.cls}`}>
            <span class={`w-1.5 h-1.5 rounded-full ${availabilityBadge.dot} ${availabilityBadge.label === 'In Stock' ? 'animate-pulse' : ''}`}></span>
            {availabilityBadge.label}
          </div>

          <!-- Specs table -->
          <div data-hero-step class="mt-6 rounded-xl border hairline overflow-hidden" style="box-shadow: var(--shadow-card)">
            <div data-reveal-group data-reveal-stagger="0.04" data-reveal-y="10" class="grid grid-cols-2 divide-x divide-y divide-white/[0.05]">
              {specs.map((s: any) => (
                <div data-reveal-item class="px-4 py-3 bg-ink-800/50">
                  <div class="font-mono text-[11px] tracking-widest uppercase text-chrome-200/60 mb-0.5">{s.label}</div>
                  <div class="text-sm font-medium text-chrome-50">{s.value}</div>
                </div>
              ))}
            </div>
          </div>

          <!-- Action buttons -->
          <div data-hero-step class="mt-6 flex flex-wrap gap-3">
            <button
              id="add-enquiry-btn"
              data-product={JSON.stringify({ id: product.id, code: product.code, name: product.name, category: product.category, diameter: product.diameter || '' })}
              class="btn-shine inline-flex items-center gap-2 px-5 py-3 rounded-md bg-gold text-ink-900 font-medium text-sm hover:shadow-glow-cyan transition-all"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 4h7l4 4v12a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1z"/><path d="M15 4v5h5"/><path d="M11 13h6"/><path d="M11 17h4"/><path d="M5 8H3"/><path d="M5 13H3"/><path d="M5 18H3"/></svg>
              Add to Enquiry List
            </button>
            <button
              id="enquire-now-btn"
              data-product={JSON.stringify({ id: product.id, code: product.code, name: product.name, category: product.category, diameter: product.diameter || '' })}
              class="btn-shine inline-flex items-center gap-2 px-5 py-3 rounded-md border hairline-strong text-chrome-50 hover:border-gold/60 hover:text-gold font-medium text-sm bg-ink-600/40 transition-all"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              Enquire Now
            </button>
            <a
              href={`https://wa.me/94766550249?text=${waMsg}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-shine inline-flex items-center gap-2 px-5 py-3 rounded-md bg-emerald-600/90 hover:bg-emerald-500 text-white font-medium text-sm transition-all"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.557 4.126 1.533 5.862L.057 23.5l5.784-1.517A11.944 11.944 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.816 9.816 0 0 1-5.001-1.372l-.358-.213-3.726.977.995-3.633-.233-.373A9.818 9.818 0 0 1 2.182 12C2.182 6.573 6.573 2.182 12 2.182S21.818 6.573 21.818 12 17.427 21.818 12 21.818z"/></svg>
              WhatsApp
            </a>
          </div>

          <p class="mt-4 text-xs text-chrome-200/60 font-mono">Product ID: {product.id}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related products -->
  {related.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 md:px-6 py-10 md:py-14">
      <div class="flex items-center justify-between mb-6">
        <h2 data-reveal class="font-display text-lg md:text-xl font-semibold text-chrome-50">More in {cat?.name}</h2>
        <a href={`/categories/${product.category}`} data-reveal class="font-mono text-[12px] tracking-widest uppercase text-chrome-200/70 hover:text-gold transition-colors flex items-center gap-1">
          View all
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12,5 19,12 12,19"/></svg>
        </a>
      </div>
      <div data-reveal-group data-reveal-stagger="0.06" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {related.map(p => (
          <a href={`/products/${p.id}`}
             data-reveal-item
             data-tilt
             data-tilt-max="6"
             class="group flex flex-col rounded-xl border hairline bg-ink-800/60 hover:border-gold/40 transition-all duration-200 overflow-hidden"
             style="box-shadow: var(--shadow-card)"
          >
            <div class="aspect-square bg-ink-700/30 border-b hairline flex items-center justify-center">
              {p.image
                ? <img src={p.image} alt={p.name} class="w-full h-full object-contain p-3" loading="lazy" />
                : <div class="w-12 h-12 opacity-70 group-hover:opacity-100 transition-opacity">
                    <BearingVisual iconType={cat?.iconType ?? 'groove'} size={48} />
                  </div>
              }
            </div>
            <div class="p-3">
              <div class="font-display text-sm font-semibold text-chrome-50 group-hover:text-gold transition-colors">{p.code}</div>
              {p.diameter && <div class="mt-0.5 text-[12px] text-chrome-200/60 font-mono truncate">{p.diameter}</div>}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

</Layout>

<script>
  const addBtn = document.getElementById('add-enquiry-btn') as HTMLButtonElement | null;
  const enquireBtn = document.getElementById('enquire-now-btn') as HTMLButtonElement | null;

  addBtn?.addEventListener('click', () => {
    const product = JSON.parse(addBtn.dataset.product!);
    window.rcbList?.add(product);
  });

  enquireBtn?.addEventListener('click', () => {
    const product = JSON.parse(enquireBtn.dataset.product!);
    window.openEnquiry?.([product]);
  });
</script>
