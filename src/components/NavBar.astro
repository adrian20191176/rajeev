---
import { CATEGORIES } from "../data/rcb";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const navLinks = [
  { href: "/categories", label: "Categories" },
  { href: "/about",      label: "About Us"   },
  { href: "/contact",    label: "Contact Us" },
];
---

<header id="site-header" class="sticky top-0 z-40 transition-all duration-300">
  <!-- Utility bar (desktop) -->
  <div class="hidden md:flex items-center justify-between border-b hairline px-6 py-1.5 font-mono text-[10px] tracking-[0.22em] uppercase text-chrome-200/60 bg-ink-900/95 backdrop-blur-md">
    <div class="flex items-center gap-5">
      <span class="flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 live-dot"></span>
        24/7 Service
      </span>
      <span>NTN · NSK · NACHI · KOYO · FAG · SKF · TIMKEN</span>
    </div>
    <div class="flex items-center gap-5">
      <a href="tel:+94766550249" class="hover:text-cyan-brand transition-colors">+94 766 550 249</a>
      <span class="text-chrome-200/30">·</span>
      <a href="mailto:info@royalcrownbearings.com" class="hover:text-cyan-brand transition-colors">info@royalcrownbearings.com</a>
    </div>
  </div>

  <!-- Main nav row -->
  <div id="nav-main" class="flex items-center justify-between gap-4 px-4 md:px-6 py-3 bg-ink-900/0 transition-all duration-300">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 shrink-0" aria-label="Royal Crown Bearings — Home">
      <div class="relative w-10 h-10 sm:w-11 sm:h-11 rounded-md border hairline-strong bg-gradient-to-b from-ink-600 to-ink-800 grid place-items-center overflow-hidden">
        <div class="w-7 h-7 sm:w-8 sm:h-8" style="
          background: linear-gradient(135deg, #F4F6FA 0%, #C2CCDB 35%, #5C6A82 70%, #C2CCDB 100%);
          -webkit-mask-image: url('/logo.svg');
          mask-image: url('/logo.svg');
          -webkit-mask-repeat: no-repeat;
          mask-repeat: no-repeat;
          -webkit-mask-position: center;
          mask-position: center;
          -webkit-mask-size: contain;
          mask-size: contain;
        "></div>
        <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(60% 50% at 50% 0%,rgba(0,224,255,0.18),transparent 70%)"></div>
        <div class="absolute -inset-px rounded-md pointer-events-none" style="box-shadow:inset 0 1px 0 rgba(255,255,255,0.10)"></div>
      </div>
      <div class="leading-tight hidden xs:block">
        <div class="font-display text-[14px] sm:text-[15px] font-semibold tracking-tight text-chrome-50">Royal Crown</div>
        <div class="font-mono text-[9px] tracking-[0.28em] uppercase text-chrome-200/60">Bearings · LK</div>
      </div>
    </a>

    <!-- Desktop nav links -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
      {navLinks.map(({ href, label }) => {
        const active = currentPath.startsWith(href);
        return (
          <a
            href={href}
            class={`relative px-3 py-2 text-sm tracking-tight transition-colors ${active ? "text-cyan-brand nav-link-active" : "text-chrome-100 hover:text-chrome-50"}`}
          >
            {label}
          </a>
        );
      })}
    </nav>

    <!-- Right cluster -->
    <div class="flex items-center gap-2">
      <!-- Search trigger (desktop) -->
      <button onclick="openSearchPalette()" aria-label="Search products"
              class="hidden sm:flex items-center gap-2 px-3 py-2 rounded-md border hairline-strong bg-ink-800/60 text-chrome-200/80 hover:text-chrome-50 hover:border-cyan-brand/40 text-sm min-w-[200px] lg:min-w-[220px] transition-all">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" class="shrink-0">
          <circle cx="11" cy="11" r="6"/><line x1="20" y1="20" x2="15.5" y2="15.5"/>
        </svg>
        <span class="font-mono text-[11px] tracking-[0.18em] uppercase flex-1 text-left">Search part / category</span>
        <span class="ml-auto font-mono text-[10px] text-chrome-200/40 border hairline rounded px-1.5 py-0.5">⌘K</span>
      </button>

      <!-- Search trigger (mobile) -->
      <button onclick="openSearchPalette()" aria-label="Search"
              class="sm:hidden p-2 rounded-md border hairline-strong text-chrome-50 hover:border-cyan-brand/40 hover:text-cyan-brand transition-all">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <circle cx="11" cy="11" r="6"/><line x1="20" y1="20" x2="15.5" y2="15.5"/>
        </svg>
      </button>

      <!-- Enquiry list button -->
      <a href="/enquiry-list"
         class="relative flex items-center gap-2 px-3 py-2 rounded-md border hairline-strong bg-ink-800/60 hover:border-amber-signal/50 text-chrome-50 text-sm transition-all"
         aria-label="Enquiry List">
        <!-- List icon -->
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 4h7l4 4v12a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1z"/>
          <path d="M15 4v5h5"/>
          <path d="M11 13h6"/><path d="M11 17h4"/>
          <path d="M5 8H3"/><path d="M5 13H3"/><path d="M5 18H3"/>
        </svg>
        <span class="hidden md:inline">Enquiry List</span>
        <span data-enquiry-count
              class="grid place-items-center min-w-[22px] h-[22px] px-1.5 rounded text-[11px] font-mono font-semibold bg-ink-600 text-chrome-100 transition-all">
          0
        </span>
      </a>

      <!-- Hamburger (mobile) -->
      <button id="mobile-menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu"
              class="lg:hidden p-2 rounded-md border hairline-strong text-chrome-50 hover:text-cyan-brand transition-all">
        <svg id="icon-menu" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <line x1="4" y1="7"  x2="20" y2="7"/>
          <line x1="4" y1="12" x2="20" y2="12"/>
          <line x1="4" y1="17" x2="20" y2="17"/>
        </svg>
        <svg id="icon-close" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" class="hidden">
          <line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden border-t hairline px-4 py-3 bg-ink-900/95 backdrop-blur-md flex-col gap-1">
    {navLinks.map(({ href, label }) => {
      const active = currentPath.startsWith(href);
      return (
        <a href={href}
           class={`block text-left px-3 py-3 rounded-md transition-colors text-[15px] ${active ? "text-cyan-brand bg-cyan-brand/5" : "text-chrome-50 hover:text-cyan-brand hover:bg-white/5"}`}>
          {label}
        </a>
      );
    })}
    <!-- WhatsApp quick link on mobile -->
    <a href="https://wa.me/94766550249" target="_blank" rel="noopener"
       class="mt-2 flex items-center gap-2 px-3 py-3 rounded-md text-amber-signal hover:bg-amber-signal/10 transition-colors text-[15px]">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
        <path d="M20.5 3.5A11 11 0 0 0 3.7 17.3L2 22l4.8-1.6A11 11 0 1 0 20.5 3.5zm-8.6 17.1a9 9 0 0 1-4.6-1.3l-.3-.2-2.8 1 .9-2.8-.2-.3a9 9 0 1 1 7 3.6zm5-6.7c-.3-.2-1.6-.8-1.9-.9-.3-.1-.4-.1-.6.1l-.8 1c-.2.2-.3.2-.6.1-.3-.2-1.2-.4-2.3-1.4a9 9 0 0 1-1.7-2.1c-.2-.3 0-.5.1-.6l.5-.6c.1-.1.1-.3.2-.5l.1-.4c0-.2 0-.3-.1-.5l-.7-1.7c-.2-.4-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.2.3-.9.9-.9 2.2s.9 2.6 1 2.8c.1.2 1.8 2.7 4.4 3.8 1.6.7 2.2.7 3 .6.5-.1 1.6-.6 1.8-1.3.2-.6.2-1.2.2-1.3-.1-.1-.3-.2-.6-.4z"/>
      </svg>
      WhatsApp +94 766 550 249
    </a>
  </div>
</header>

<script>
  // Scroll effect on navbar
  const header = document.getElementById('site-header');
  const navMain = document.getElementById('nav-main');
  const onScroll = () => {
    const scrolled = window.scrollY > 8;
    if (scrolled) {
      header?.classList.add('border-b', 'hairline');
      navMain?.classList.add('bg-ink-900/85', 'backdrop-blur-md');
      navMain?.classList.remove('bg-ink-900/0');
    } else {
      header?.classList.remove('border-b', 'hairline');
      navMain?.classList.remove('bg-ink-900/85', 'backdrop-blur-md');
      navMain?.classList.add('bg-ink-900/0');
    }
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Mobile menu toggle
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  const iconMenu  = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const open = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', !open);
    menu?.classList.toggle('flex', open);
    iconMenu?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
