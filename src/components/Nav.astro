---
import { getBrands, getCategories, getBusiness } from "../data/rcb.js";

interface Props {
  activeNav?: string;
}
const { activeNav } = Astro.props;
const [BRANDS, CATEGORIES, BUSINESS] = await Promise.all([
  getBrands(),
  getCategories(),
  getBusiness(),
]);
const topCategories = CATEGORIES.slice(0, 6);
const phoneHref = `tel:${(BUSINESS.phone ?? "").replace(/\s/g, "")}`;
const waHref = `https://wa.me/${BUSINESS.whatsapp ?? ""}`;

const links = [
  { href: "/categories", label: "Categories", key: "categories" },
  { href: "/about", label: "About Us", key: "about" },
  { href: "/contact", label: "Contact Us", key: "contact" },
];
---

<header id="site-nav" class="sticky top-0 z-40 transition-all duration-300">
  <!-- Utility bar -->
  <div
    class="hidden md:flex items-center justify-between border-b hairline px-6 py-1.5 font-mono text-[12px] tracking-widest uppercase text-chrome-200/75"
  >
    <div class="flex items-center gap-5 min-w-0 flex-1">
      <span class="flex items-center gap-1.5 flex-shrink-0">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"
        ></span>24/7 Service
      </span>
      <span class="truncate">{BRANDS.map((b) => b.name).join(" · ")}</span>
    </div>
    <div class="flex items-center gap-5 flex-shrink-0">
      <a href="tel:+94766550249" class="hover:text-gold whitespace-nowrap"
        >+94 766 550 249</a
      >
      <span class="text-chrome-200/50">·</span>
      <a
        href="mailto:royalcrownbearings@gmail.com"
        class="hover:text-gold whitespace-nowrap"
        >royalcrownbearings@gmail.com</a
      >
    </div>
  </div>

  <!-- Main nav bar -->
  <div class="flex items-center justify-between gap-4 px-4 md:px-6 py-3">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5" aria-label="Home">
      <div
        class="relative w-10 h-10 sm:w-11 sm:h-11 rounded-md border hairline-strong bg-gradient-to-b from-ink-500 to-ink-700 grid place-items-center overflow-hidden"
      >
        <div
          class="w-7 h-7 sm:w-8 sm:h-8"
          style="
          background: linear-gradient(135deg, #F4F6FA 0%, #D4AF37 40%, #C49B2A 70%, #D4AF37 100%);
          -webkit-mask-image: url(/logo.svg);
          mask-image: url(/logo.svg);
          -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat;
          -webkit-mask-position: center; mask-position: center;
          -webkit-mask-size: contain; mask-size: contain;
        "
        >
        </div>
        <div
          class="absolute inset-0 pointer-events-none"
          style="background: radial-gradient(60% 50% at 50% 0%, rgba(212,175,55,0.20), transparent 70%)"
        >
        </div>
      </div>
      <div class="leading-tight">
        <div
          class="font-display text-[14px] sm:text-[15px] font-semibold tracking-tight text-chrome-50 whitespace-nowrap"
        >
          Royal Crown Bearings
        </div>
      </div>
    </a>

    <!-- Desktop nav links -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Primary">
      {
        links.map((l) => (
          <a
            href={l.href}
            class={`relative px-3 py-2 text-sm tracking-tight transition-colors ${activeNav === l.key ? "text-gold" : "text-chrome-100 hover:text-chrome-50"}`}
          >
            {l.label}
            {activeNav === l.key && (
              <span class="absolute left-3 right-3 -bottom-px h-px bg-gold" />
            )}
          </a>
        ))
      }
    </nav>

    <!-- Right controls -->
    <div class="flex items-center gap-2">
      <!-- Search (desktop) -->
      <button
        class="open-search hidden sm:flex items-center gap-2 px-3 py-2 rounded-md border hairline-strong bg-ink-600/60 text-chrome-200/80 hover:text-chrome-50 hover:border-gold/40 text-sm min-w-[200px]"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          ><circle cx="11" cy="11" r="6"></circle><line
            x1="20"
            y1="20"
            x2="15.5"
            y2="15.5"></line></svg
        >
        <span class="font-mono text-[12px] tracking-widest uppercase"
          >Search part / category</span
        >
        <span
          class="ml-auto font-mono text-[12px] text-chrome-200/75 border hairline rounded px-1.5 py-0.5"
          >⌘K</span
        >
      </button>
      <!-- Search (mobile) -->
      <button
        class="open-search sm:hidden w-10 h-10 grid place-items-center rounded-md border hairline-strong text-chrome-50"
        aria-label="Search"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          ><circle cx="11" cy="11" r="6"></circle><line
            x1="20"
            y1="20"
            x2="15.5"
            y2="15.5"></line></svg
        >
      </button>

      <!-- Enquiry list -->
      <a
        href="/enquiry-list"
        class="relative flex items-center gap-2 px-3 py-2 rounded-md border hairline-strong bg-ink-600/60 hover:border-gold/50 text-chrome-50 text-sm"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M9 4h7l4 4v12a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1z"
          ></path><path d="M15 4v5h5"></path><path d="M11 13h6"></path><path
            d="M11 17h4"></path><path d="M5 8H3"></path><path d="M5 13H3"
          ></path><path d="M5 18H3"></path></svg
        >
        <span class="hidden md:inline">Enquiry List</span>
        <span
          id="enquiry-count"
          class="grid place-items-center min-w-[22px] h-[22px] px-1.5 rounded text-[12px] font-mono font-semibold bg-ink-500 text-chrome-100 transition-colors"
          >0</span
        >
      </a>

      <!-- Mobile menu toggle -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden w-10 h-10 sm:w-11 sm:h-11 grid place-items-center rounded-md border hairline-strong text-chrome-50"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          ><line x1="4" y1="7" x2="20" y2="7"></line><line
            x1="4"
            y1="12"
            x2="20"
            y2="12"></line><line x1="4" y1="17" x2="20" y2="17"></line></svg
        >
      </button>
    </div>
  </div>
</header>

<!-- Mobile drawer backdrop — must live OUTSIDE #site-nav: the elevated nav's
     backdrop-filter makes the header the containing block for fixed
     descendants, which would pin these to the header instead of the viewport. -->
<div
  id="mobile-nav-backdrop"
  class="lg:hidden fixed inset-0 z-[90] bg-ink-900/70 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"
>
</div>

<!-- Mobile slide-in drawer -->
<div
  id="mobile-nav"
  inert
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Site menu"
  class="lg:hidden fixed top-0 right-0 z-[95] h-full w-[86%] max-w-[380px] bg-ink-800 border-l hairline-strong flex flex-col transition-transform duration-300 ease-out"
>
  <div
    class="shrink-0 flex items-center justify-between gap-4 px-4 py-3 border-b hairline"
  >
    <span
      class="font-mono text-[12px] tracking-[0.28em] uppercase text-chrome-200/75"
      >Menu</span
    >
    <button
      id="mobile-nav-close"
      class="w-10 h-10 grid place-items-center rounded-md border hairline-strong text-chrome-50"
      aria-label="Close menu"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        ><line x1="6" y1="6" x2="18" y2="18"></line><line
          x1="18"
          y1="6"
          x2="6"
          y2="18"></line></svg
      >
    </button>
  </div>

  <div class="flex-1 overflow-y-auto overscroll-contain">
    <!-- Main links -->
    <nav class="flex flex-col px-2 py-3" aria-label="Primary">
      {
        links.map((l) => (
          <a
            href={l.href}
            class={`flex items-center min-h-[48px] px-3 rounded-md text-[15px] font-medium transition-colors ${activeNav === l.key ? "text-gold bg-gold/10" : "text-chrome-50 hover:bg-ink-700/60"}`}
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="border-t hairline mx-2"></div>

    <!-- Shop by category -->
    <div
      class="px-5 pt-3 pb-1 font-mono text-[12px] tracking-widest uppercase text-chrome-200/75"
    >
      Shop by Category
    </div>
    <nav class="flex flex-col px-2 pb-2" aria-label="Shop by category">
      {
        topCategories.map((c) => (
          <a
            href={`/categories/${c.slug}`}
            class="flex items-center min-h-[48px] px-3 rounded-md text-[15px] text-chrome-100 hover:bg-ink-700/60 hover:text-chrome-50 transition-colors"
          >
            {c.name}
          </a>
        ))
      }
      <a
        href="/categories"
        class="flex items-center justify-between min-h-[48px] px-3 rounded-md text-[15px] font-medium text-gold hover:bg-gold/10 transition-colors"
      >
        All {CATEGORIES.length} Categories
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
            points="12,5 19,12 12,19"></polyline></svg
        >
      </a>
    </nav>

    <div class="border-t hairline mx-2"></div>

    <!-- Enquiry list + search -->
    <div class="flex flex-col px-2 py-2">
      <a
        href="/enquiry-list"
        class="flex items-center gap-3 min-h-[48px] px-3 rounded-md text-[15px] text-chrome-50 hover:bg-ink-700/60 transition-colors"
      >
        <svg
          width="17"
          height="17"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="shrink-0"
          ><path
            d="M9 4h7l4 4v12a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1z"
          ></path><path d="M15 4v5h5"></path><path d="M11 13h6"></path><path
            d="M11 17h4"></path><path d="M5 8H3"></path><path d="M5 13H3"
          ></path><path d="M5 18H3"></path></svg
        >
        <span class="flex-1">Enquiry List</span>
        <span
          id="enquiry-count-drawer"
          class="grid place-items-center min-w-[22px] h-[22px] px-1.5 rounded text-[12px] font-mono font-semibold bg-ink-500 text-chrome-100 transition-colors"
          >0</span
        >
      </a>
      <button
        id="mobile-nav-search"
        class="open-search flex items-center gap-3 min-h-[48px] px-3 rounded-md text-[15px] text-chrome-50 hover:bg-ink-700/60 transition-colors text-left w-full"
      >
        <svg
          width="17"
          height="17"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          class="shrink-0"
          ><circle cx="11" cy="11" r="6"></circle><line
            x1="20"
            y1="20"
            x2="15.5"
            y2="15.5"></line></svg
        >
        <span class="flex-1">Search part / category</span>
      </button>
    </div>
  </div>

  <!-- Pinned bottom: Call + WhatsApp -->
  <div class="shrink-0 border-t hairline p-3 grid grid-cols-2 gap-2 bg-ink-800">
    <a
      href={phoneHref}
      class="btn-shine inline-flex items-center justify-center gap-2 min-h-[52px] rounded-md border hairline-strong text-chrome-50 hover:border-gold/60 bg-ink-600/40 text-sm font-medium"
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path
          d="M5 4h4l2 5-3 2a12 12 0 0 0 5 5l2-3 5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"
        ></path></svg
      >
      Call
    </a>
    <a
      href={waHref}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-shine inline-flex items-center justify-center gap-2 min-h-[52px] rounded-md bg-emerald-600/90 hover:bg-emerald-500 text-white text-sm font-medium"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
        ><path
          d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
        ></path><path
          d="M12 0C5.373 0 0 5.373 0 12c0 2.127.557 4.126 1.533 5.862L.057 23.5l5.784-1.517A11.944 11.944 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.816 9.816 0 0 1-5.001-1.372l-.358-.213-3.726.977.995-3.633-.233-.373A9.818 9.818 0 0 1 2.182 12C2.182 6.573 6.573 2.182 12 2.182S21.818 6.573 21.818 12 17.427 21.818 12 21.818z"
        ></path></svg
      >
      WhatsApp
    </a>
  </div>
</div>

<style>
  /* The off-canvas position is owned here, not by a translate-x-full utility:
     Tailwind v4 translate-* utilities set the native `translate` property,
     which a `transform` override cannot cancel. */
  #mobile-nav {
    transform: translateX(100%);
  }
  #mobile-nav.drawer-open {
    transform: translateX(0);
  }
  #mobile-nav-backdrop.drawer-open {
    opacity: 1;
    pointer-events: auto;
  }
</style>

<script>
  const btn = document.getElementById(
    "mobile-menu-btn",
  ) as HTMLButtonElement | null;
  const closeBtn = document.getElementById(
    "mobile-nav-close",
  ) as HTMLButtonElement | null;
  const drawer = document.getElementById("mobile-nav") as HTMLElement | null;
  const backdrop = document.getElementById(
    "mobile-nav-backdrop",
  ) as HTMLElement | null;
  const mainEl = document.querySelector("main");
  const footerEl = document.querySelector("footer");

  function openDrawer() {
    if (!drawer || !backdrop || !btn) return;
    drawer.classList.add("drawer-open");
    backdrop.classList.add("drawer-open");
    drawer.removeAttribute("inert");
    drawer.setAttribute("aria-hidden", "false");
    btn.setAttribute("aria-expanded", "true");
    btn.setAttribute("aria-label", "Close menu");
    document.documentElement.classList.add("overflow-hidden");
    document.body.classList.add("overflow-hidden");
    mainEl?.setAttribute("inert", "");
    footerEl?.setAttribute("inert", "");
    document.addEventListener("keydown", onKeydown);
    closeBtn?.focus();
  }

  function closeDrawer() {
    if (!drawer || !backdrop || !btn) return;
    drawer.classList.remove("drawer-open");
    backdrop.classList.remove("drawer-open");
    drawer.setAttribute("inert", "");
    drawer.setAttribute("aria-hidden", "true");
    btn.setAttribute("aria-expanded", "false");
    btn.setAttribute("aria-label", "Open menu");
    document.documentElement.classList.remove("overflow-hidden");
    document.body.classList.remove("overflow-hidden");
    mainEl?.removeAttribute("inert");
    footerEl?.removeAttribute("inert");
    document.removeEventListener("keydown", onKeydown);
    btn.focus();
  }

  function onKeydown(e: KeyboardEvent) {
    if (e.key === "Escape") closeDrawer();
  }

  btn?.addEventListener("click", () => {
    if (drawer?.classList.contains("drawer-open")) closeDrawer();
    else openDrawer();
  });
  closeBtn?.addEventListener("click", closeDrawer);
  backdrop?.addEventListener("click", closeDrawer);
  drawer
    ?.querySelectorAll("a")
    .forEach((a) => a.addEventListener("click", closeDrawer));
  document
    .getElementById("mobile-nav-search")
    ?.addEventListener("click", closeDrawer);

  // Force-close if the viewport crosses into the desktop nav breakpoint
  // while the drawer is open (e.g. rotating a tablet, resizing a window).
  window.matchMedia("(min-width: 1024px)").addEventListener("change", (e) => {
    if (e.matches) closeDrawer();
  });

  // Keep --nav-h in sync with the real rendered header height so sticky
  // elements (e.g. the category filter toolbar) don't tuck underneath it.
  const nav = document.getElementById("site-nav");
  if (nav) {
    const setNavHeight = () => {
      document.documentElement.style.setProperty(
        "--nav-h",
        `${nav.offsetHeight}px`,
      );
    };
    setNavHeight();
    new ResizeObserver(setNavHeight).observe(nav);
  }
</script>
