---
import { contact } from "../data/catalog";

const navItems = [
	{ label: "Home", href: "/" },
	{ label: "Categories", href: "/categories/" },
	{ label: "About", href: "/#about" },
	{ label: "Contact", href: "/#contact" },
];

const { current = "" } = Astro.props;
---

<header class="site-header" data-reveal>
	<a class="brand-mark" href="/" aria-label="Royal Crown Bearings home">
		<img src="/images/logo.svg" alt="" width="1034" height="1109" />
		<span>
			<strong>Royal Crown Bearings</strong>
			<small>Industrial supply</small>
		</span>
	</a>

	<button class="menu-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false" data-menu-toggle>
		<span></span>
		<span></span>
	</button>

	<nav class="site-nav" aria-label="Primary navigation" data-site-nav>
		{navItems.map((item) => (
			<a href={item.href} aria-current={current === item.label ? "page" : undefined}>{item.label}</a>
		))}
		<a class="nav-cta" href={contact.whatsapp}>WhatsApp</a>
	</nav>
</header>

<script is:inline>
	const menuButton = document.querySelector("[data-menu-toggle]");
	const siteNav = document.querySelector("[data-site-nav]");

	menuButton?.addEventListener("click", () => {
		const isOpen = siteNav?.classList.toggle("is-open") ?? false;
		menuButton.setAttribute("aria-expanded", String(isOpen));
	});

	siteNav?.querySelectorAll("a").forEach((link) => {
		link.addEventListener("click", () => {
			siteNav.classList.remove("is-open");
			menuButton?.setAttribute("aria-expanded", "false");
		});
	});
</script>
