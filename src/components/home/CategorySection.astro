---
const categories = [
	{
		title: 'Bearings',
		description: 'Deep groove, tapered roller, pillow block, and common industrial bearing sizes.',
	},
	{
		title: 'V-Belts',
		description: 'Classical and wedge belts for machinery, automotive, and workshop replacement needs.',
	},
	{
		title: 'Oil Seals',
		description: 'Rotary shaft seals and standard metric sizes for pumps, motors, and gear units.',
	},
];
---

<section class="section section--light" id="products">
	<div class="container section-heading">
		<p class="section-kicker">Shop by category</p>
		<h2>Find the spare part family first.</h2>
		<p>Use the category cards as the first path into the catalogue while product pages are planned.</p>
	</div>

	<div class="container category-grid">
		{categories.map((category) => (
			<article class="category-card">
				<div class="category-card__icon" aria-hidden="true"></div>
				<h3>{category.title}</h3>
				<p>{category.description}</p>
				<a href="#featured-products">View Products</a>
			</article>
		))}
	</div>
</section>
