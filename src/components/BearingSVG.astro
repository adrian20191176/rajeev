---
// Geometric bearing SVG visual — concentric rings with balls/rollers
// No hand-drawn shapes, pure circles/lines/rects only

interface Props {
  size?: number;
  type?: "groove" | "cylindrical" | "needle" | "tapered" | "thrust" | "mini" | "angular" | "selfalign" | "spherical" | "vbelt" | "tooth" | "seal" | "housing" | "uc";
  class?: string;
  id?: string;
  spinClass?: string;
}

const {
  size = 280,
  type = "groove",
  class: className = "",
  id,
  spinClass = "",
} = Astro.props;

const c     = size / 2;
const outer = size * 0.46;
const inner = size * 0.30;
const bore  = size * 0.18;

const ringR = (outer + inner) / 2;
const elemR = (outer - inner) / 2 - 1;

const count = type === "needle" ? 18 : type === "cylindrical" ? 12 : type === "thrust" ? 14 : type === "mini" ? 8 : 10;

type Element = { tag: "circle"; cx: number; cy: number; r: number } | { tag: "rect"; x: number; y: number; w: number; h: number; angle: number; isNeedle?: boolean } | { tag: "poly"; pts: string; angle: number };

const elements: Element[] = [];
for (let i = 0; i < count; i++) {
  const a = (i / count) * Math.PI * 2;
  const x = c + Math.cos(a) * ringR;
  const y = c + Math.sin(a) * ringR;
  const angle = (a * 180) / Math.PI + 90;

  if (type === "cylindrical" || type === "needle") {
    const w = type === "needle" ? elemR * 0.8 : elemR * 1.4;
    const h = elemR * 1.6;
    elements.push({ tag: "rect", x: x - w / 2, y: y - h / 2, w, h, angle, isNeedle: type === "needle" });
  } else if (type === "tapered") {
    const w = elemR * 1.2;
    const h = elemR * 2;
    const x0 = -w / 2, x1 = w / 2, x2 = w * 0.3, x3 = -w * 0.3;
    elements.push({ tag: "poly", pts: `${x0},${h / 2} ${x1},${h / 2} ${x2},${-h / 2} ${x3},${-h / 2}`, angle: `${angle} ${x} ${y}` as unknown as number });
  } else {
    elements.push({ tag: "circle", cx: x, cy: y, r: elemR });
  }
}

// Belt / seal visuals handled separately
const isBelt = type === "vbelt" || type === "tooth";
const isSeal = type === "seal" || type === "housing" || type === "uc";
---

<svg
  viewBox={`0 0 ${size} ${size}`}
  class={className}
  id={id}
  aria-hidden="true"
  role="img"
>
  <defs>
    <radialGradient id={`rg-chrome-${id || type}`} cx="0.3" cy="0.3" r="0.8">
      <stop offset="0%"   stop-color="#E2E7F0"/>
      <stop offset="40%"  stop-color="#8A98B0"/>
      <stop offset="100%" stop-color="#1C2333"/>
    </radialGradient>
    <radialGradient id={`rg-ball-${id || type}`} cx="0.3" cy="0.3" r="0.8">
      <stop offset="0%"   stop-color="#F4F6FA"/>
      <stop offset="50%"  stop-color="#5C6A82"/>
      <stop offset="100%" stop-color="#0A0E14"/>
    </radialGradient>
    <radialGradient id={`rg-ring-${id || type}`} cx="0.5" cy="0.5" r="0.5">
      <stop offset="0%"   stop-color="#2A3344"/>
      <stop offset="100%" stop-color="#151B28"/>
    </radialGradient>
  </defs>

  {isBelt ? (
    <!-- Belt visual: concentric oval lines with tooth marks -->
    <>
      <ellipse cx={c} cy={c} rx={outer} ry={outer * 0.65} fill="none" stroke="rgba(0,224,255,0.15)" stroke-width="2"/>
      <ellipse cx={c} cy={c} rx={inner} ry={inner * 0.65} fill="none" stroke="rgba(0,224,255,0.1)"  stroke-width="1.5"/>
      {type === "tooth" && Array.from({ length: 16 }, (_, i) => {
        const a = (i / 16) * Math.PI * 2;
        const rx2 = outer * 0.75; const ry2 = outer * 0.49;
        const x1 = c + Math.cos(a) * rx2;
        const y1 = c + Math.sin(a) * ry2;
        return <line x1={x1} y1={y1} x2={c + Math.cos(a) * (rx2 * 0.88)} y2={c + Math.sin(a) * (ry2 * 0.88)} stroke="rgba(0,224,255,0.25)" stroke-width="1.5" stroke-linecap="round"/>;
      })}
      <ellipse cx={c} cy={c} rx={bore * 1.2} ry={bore * 0.8} fill={`url(#rg-ring-${id || type})`}/>
    </>
  ) : isSeal ? (
    <!-- Seal / housing visual: shaft sealing rings -->
    <>
      <circle cx={c} cy={c} r={outer}       fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="2"/>
      <circle cx={c} cy={c} r={outer * 0.82} fill="none" stroke="rgba(0,224,255,0.20)" stroke-width="1.5" stroke-dasharray="6 4"/>
      <circle cx={c} cy={c} r={inner}        fill={`url(#rg-ring-${id || type})`} stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
      <circle cx={c} cy={c} r={bore}         fill={`url(#rg-chrome-${id || type})`} stroke="rgba(255,255,255,0.2)" stroke-width="0.5"/>
      {Array.from({ length: 12 }, (_, i) => {
        const a = (i / 12) * Math.PI * 2;
        return <line
          x1={c + Math.cos(a) * inner}
          y1={c + Math.sin(a) * inner}
          x2={c + Math.cos(a) * outer}
          y2={c + Math.sin(a) * outer}
          stroke="rgba(255,255,255,0.06)"
          stroke-width="1"
        />;
      })}
    </>
  ) : (
    <!-- Standard bearing visual -->
    <>
      <!-- Outer ring -->
      <circle cx={c} cy={c} r={outer} fill={`url(#rg-ring-${id || type})`} stroke="rgba(255,255,255,0.12)" stroke-width="1.5"/>
      <circle cx={c} cy={c} r={outer} fill="none" stroke="rgba(255,255,255,0.06)" stroke-width={outer * 0.28} class={spinClass}/>

      <!-- Raceway groove -->
      <circle cx={c} cy={c} r={ringR} fill="none" stroke="rgba(255,255,255,0.04)" stroke-width={elemR * 2.2}/>

      <!-- Rolling elements (with spin class if provided) -->
      <g class={spinClass}>
        {elements.map((el) => {
          if (el.tag === "circle") {
            return <circle cx={el.cx} cy={el.cy} r={el.r} fill={`url(#rg-ball-${id || type})`} stroke="rgba(255,255,255,0.25)" stroke-width="0.5"/>;
          }
          if (el.tag === "rect") {
            return (
              <g transform={`rotate(${el.angle} ${c + (el.x + el.w / 2) - c + (el.x + el.w / 2)} ${c + (el.y + el.h / 2) - c + (el.y + el.h / 2)})`}>
                <rect x={el.x} y={el.y} width={el.w} height={el.h} rx="1"
                      fill={`url(#rg-chrome-${id || type})`} stroke="rgba(255,255,255,0.25)" stroke-width="0.5"/>
              </g>
            );
          }
          if (el.tag === "poly") {
            return (
              <polygon points={el.pts}
                       transform={`translate(${c + Math.cos(((elements.indexOf(el) / count) * Math.PI * 2))} ${c}) rotate(${el.angle})`}
                       fill={`url(#rg-chrome-${id || type})`} stroke="rgba(255,255,255,0.25)" stroke-width="0.5"/>
            );
          }
        })}
      </g>

      <!-- Inner ring -->
      <circle cx={c} cy={c} r={inner} fill={`url(#rg-ring-${id || type})`} stroke="rgba(255,255,255,0.15)" stroke-width="1.5"/>

      <!-- Bore -->
      <circle cx={c} cy={c} r={bore} fill={`url(#rg-chrome-${id || type})`} stroke="rgba(255,255,255,0.2)" stroke-width="0.5"/>

      <!-- Technical tick marks around outer ring -->
      {Array.from({ length: 36 }, (_, i) => {
        const a   = (i / 36) * Math.PI * 2;
        const len = i % 3 === 0 ? 6 : 3;
        const r1  = outer + 4;
        const r2  = outer + 4 + len;
        return (
          <line
            x1={c + Math.cos(a) * r1}
            y1={c + Math.sin(a) * r1}
            x2={c + Math.cos(a) * r2}
            y2={c + Math.sin(a) * r2}
            stroke="rgba(0,224,255,0.2)"
            stroke-width="0.7"
          />
        );
      })}
    </>
  )}
</svg>
