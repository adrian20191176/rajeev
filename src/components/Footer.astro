---
const quickLinks = ['Home', 'Products', 'About', 'Contact'];
const categories = ['Bearings', 'V-Belts', 'Oil Seals', 'Industrial Tools'];
---

<footer class="site-footer" id="contact">
	<div class="container footer-grid">
		<div>
			<a class="brand brand--footer" href="/">
				<span class="brand__mark">IP</span>
				<span>Industrial Parts</span>
			</a>
			<p class="footer-copy">A dummy industrial spare parts catalogue for availability and pricing enquiries.</p>
		</div>

		<div>
			<h2>Quick Links</h2>
			<ul>
				{quickLinks.map((item) => <li><a href={`#${item.toLowerCase()}`}>{item}</a></li>)}
			</ul>
		</div>

		<div>
			<h2>Product Categories</h2>
			<ul>
				{categories.map((item) => <li><a href="#products">{item}</a></li>)}
			</ul>
		</div>

		<div>
			<h2>Contact</h2>
			<ul>
				<li>No. 00, Industrial Road</li>
				<li>Colombo, Sri Lanka</li>
				<li>Phone: +94 77 000 0000</li>
				<li>Email: sales@example.com</li>
			</ul>
		</div>
	</div>

	<div class="container footer-bottom">
		<p>Copyright {new Date().getFullYear()} Industrial Parts. All rights reserved.</p>
	</div>
</footer>
