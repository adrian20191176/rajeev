---
import { CATEGORIES } from '../data/rcb.js';
const cats = CATEGORIES.slice(0, 9);
---

<footer class="relative border-t hairline mt-24 bg-ink-900">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"></div>
  <div class="max-w-7xl mx-auto px-6 py-16 grid grid-cols-2 md:grid-cols-12 gap-8">
    <!-- Brand -->
    <div class="col-span-2 md:col-span-4">
      <a href="/" class="flex items-center gap-2.5">
        <div class="relative w-10 h-10 rounded-md border hairline-strong bg-gradient-to-b from-ink-500 to-ink-700 grid place-items-center overflow-hidden">
          <div class="w-7 h-7" style="
            background: linear-gradient(135deg, #F5F6F8 0%, #D4AF37 40%, #C49B2A 70%, #D4AF37 100%);
            -webkit-mask-image: url(/logo.svg); mask-image: url(/logo.svg);
            -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat;
            -webkit-mask-position: center; mask-position: center;
            -webkit-mask-size: contain; mask-size: contain;
          "></div>
        </div>
        <div class="leading-tight">
          <div class="font-display text-[14px] font-semibold tracking-tight text-chrome-50">Royal Crown</div>
          <div class="font-mono text-[9px] tracking-[0.28em] uppercase text-chrome-200/60">Bearings · LK</div>
        </div>
      </a>
      <p class="mt-4 text-sm text-chrome-100/80 leading-relaxed max-w-xs">
        Bearings, V-belts, oil seals and industrial components for vehicle, machinery, construction and manufacturing sectors across Sri Lanka.
      </p>
      <div class="mt-5 flex flex-col gap-2 font-mono text-[11px] tracking-widest uppercase text-chrome-200/70">
        <a href="tel:+94766550249" class="flex items-center gap-2 hover:text-gold">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4h4l2 5-3 2a12 12 0 0 0 5 5l2-3 5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"/></svg>
          +94 766 550 249
        </a>
        <a href="mailto:info@royalcrownbearings.com" class="flex items-center gap-2 hover:text-gold">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><polyline points="3,7 12,13 21,7"/></svg>
          info@royalcrownbearings.com
        </a>
        <span class="flex items-center gap-2 text-emerald-400/90">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>24/7 Service Hours
        </span>
      </div>
    </div>

    <!-- Categories -->
    <div class="col-span-1 md:col-span-5">
      <div class="font-mono text-[10px] tracking-widest uppercase text-chrome-200/60 mb-4">Categories</div>
      <ul class="grid grid-cols-2 gap-x-6 gap-y-2 text-sm">
        {cats.map(c => (
          <li>
            <a href={`/categories/${c.slug}`} class="text-chrome-100 hover:text-gold text-left transition-colors">{c.name}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Company -->
    <div class="col-span-1 md:col-span-3">
      <div class="font-mono text-[10px] tracking-widest uppercase text-chrome-200/60 mb-4">Company</div>
      <ul class="flex flex-col gap-2 text-sm">
        {[
          ['/about',        'About Us'       ],
          ['/contact',      'Contact Us'     ],
          ['/categories',   'All Categories' ],
          ['/enquiry-list', 'Enquiry List'   ],
        ].map(([href, label]) => (
          <li><a href={href} class="text-chrome-100 hover:text-gold transition-colors">{label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="border-t hairline">
    <div class="max-w-7xl mx-auto px-6 py-5 flex flex-col md:flex-row items-start md:items-center justify-between gap-3 font-mono text-[10px] tracking-widest uppercase text-chrome-200/50">
      <span>© 2026 Royal Crown Bearings · www.royalcrownbearings.com</span>
      <span>RCB · Powering Performance, Ensuring Reliability</span>
    </div>
  </div>
</footer>
