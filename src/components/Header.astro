---
const navItems = ['Home', 'Products', 'Bearings', 'V-Belts', 'Oil Seals', 'Contact'];
---

<header class="site-header">
	<div class="top-strip">
		<div class="container top-strip__inner">
			<p>Industrial spare parts supplier - Bearings, V-Belts & Oil Seals</p>
			<p>Call: +94 77 000 0000 | WhatsApp: +94 76 000 0000</p>
		</div>
	</div>

	<nav class="container navbar" aria-label="Primary navigation">
		<a class="brand" href="/" aria-label="Industrial Parts home">
			<span class="brand__mark">IP</span>
			<span>Industrial Parts</span>
		</a>

		<div class="nav-links">
			{
				navItems.map((item) => (
					<a href={`#${item.toLowerCase().replaceAll(' ', '-')}`}>{item}</a>
				))
			}
		</div>

		<a class="btn btn--accent nav-cta" href="#enquiry">Send Enquiry</a>
	</nav>
</header>
